---
const currentUser = Astro.locals.currentUser;
const categories = [
	'Infrastructure',
	'Environmental',
	'Safety',
	'Cultural Heritage',
];
---

<section class="report-shell">
	<div class="report-stage">
		<div class="stage-card">
			<div class="stage-header">
				<span class="eyebrow">Reporting flow</span>
				<h2>Submit a real report with offline-safe flow.</h2>
				<p>
					This prototype writes to D1, resolves UK councils from ONS LAD boundaries, and
					queues submissions for retry if the device is offline.
				</p>
			</div>

			<form class="report-form" data-report-form>
				<section class="step-panel" data-step>
					<div class="step-label">Step 1 of 5</div>
					<h3>Capture and identify the reporter</h3>
					<div class="field-grid">
						<label class="field">
							<span>Your name</span>
							<input
								name="name"
								type="text"
								placeholder="Jane Smith"
								value={currentUser?.displayName ?? ''}
							/>
						</label>
						<label class="field">
							<span>Email for status updates</span>
							<input
								name="email"
								type="email"
								placeholder="jane@example.com"
								value={currentUser?.email ?? ''}
							/>
						</label>
					</div>
					<label class="field">
						<span>Photo upload</span>
						<input name="photo" type="file" accept="image/*" />
						<small>Uploaded evidence now stores in R2 when the report is submitted online.</small>
					</label>
					<div class="step-actions">
						<button class="button-secondary" data-save-draft type="button">Save draft</button>
						<button class="button" data-next-step type="button">Continue</button>
					</div>
				</section>

				<section class="step-panel" data-step hidden>
					<div class="step-label">Step 2 of 5</div>
					<h3>Where is the issue?</h3>
					<div class="field-grid">
						<label class="field">
							<span>Latitude</span>
							<input name="latitude" type="number" step="0.000001" value="51.454514" />
						</label>
						<label class="field">
							<span>Longitude</span>
							<input name="longitude" type="number" step="0.000001" value="-2.587910" />
						</label>
					</div>
					<label class="field">
						<span>Nearest address or landmark</span>
						<input name="locationLabel" type="text" placeholder="College Green, Bristol" />
					</label>
					<div class="field-grid">
						<label class="field">
							<span>Search place</span>
							<input
								data-location-search
								type="text"
								placeholder="Search an address or landmark"
							/>
						</label>
						<div class="field field-actions">
							<span>Map actions</span>
							<div class="cta-row">
								<button class="button-secondary" data-search-location type="button">
									Search
								</button>
								<button class="button-secondary" data-reverse-geocode type="button">
									Refresh address
								</button>
							</div>
						</div>
					</div>
					<div class="map-frame">
						<div class="location-map" data-location-map data-map-archive-url="/api/map/maps/uk.pmtiles"></div>
					</div>
					<div class="step-actions">
						<button class="button-secondary" data-prev-step type="button">Back</button>
						<button class="button-secondary" data-detect-location type="button">Use current location</button>
						<button class="button" data-next-step type="button">Continue</button>
					</div>
				</section>

				<section class="step-panel" data-step hidden>
					<div class="step-label">Step 3 of 5</div>
					<h3>What kind of issue is it?</h3>
					<div class="choice-grid">
						{
							categories.map((category, index) => (
								<label class="choice-card">
									<input
										checked={index === 0}
										name="category"
										type="radio"
										value={category}
									/>
									<span>{category}</span>
								</label>
							))
						}
					</div>
					<div class="step-actions">
						<button class="button-secondary" data-prev-step type="button">Back</button>
						<button class="button" data-next-step type="button">Continue</button>
					</div>
				</section>

				<section class="step-panel" data-step hidden>
					<div class="step-label">Step 4 of 5</div>
					<h3>Add detail and severity</h3>
					<label class="field">
						<span>Short description</span>
						<textarea name="description" rows="4" placeholder="Describe what happened and why it matters."></textarea>
					</label>
					<label class="field">
						<span>Notes (Markdown supported)</span>
						<textarea name="notesMarkdown" rows="5" placeholder="- blocked pavement&#10;- dangerous at school pick-up"></textarea>
					</label>
					<label class="field">
						<span>Severity</span>
						<input name="severity" max="5" min="1" type="range" value="3" />
					</label>
					<div class="step-actions">
						<button class="button-secondary" data-prev-step type="button">Back</button>
						<button class="button" data-next-step type="button">Continue</button>
					</div>
				</section>

				<section class="step-panel" data-step hidden>
					<div class="step-label">Step 5 of 5</div>
					<h3>Review and submit</h3>
					<div class="summary-grid" data-summary></div>
					<p class="submit-status" data-submit-status></p>
					<div class="step-actions">
						<button class="button-secondary" data-prev-step type="button">Back</button>
						<button class="button" type="submit">Submit report</button>
					</div>
				</section>
			</form>
		</div>

		<div class="stage-card mock-card">
			<div class="phone-frame">
				<div class="phone-top stack">
					<span class="camera-dot"></span>
					<span class="location-pill">Current prototype focus: Bristol, Westminster, Manchester</span>
				</div>
				<div class="signal-list compact">
					<div class="signal">
						<strong>Offline queue</strong>
						<p>Queued reports are stored locally and retried by the service worker.</p>
					</div>
					<div class="signal">
						<strong>Evidence storage</strong>
						<p>Online uploads are persisted to R2 and shown on the public report page.</p>
					</div>
					<div class="signal">
						<strong>Map and geocoder</strong>
						<p>Location can be set by device GPS, draggable pin, or Photon search.</p>
					</div>
				</div>
				<div class="queue-badge" data-queued-badge hidden>
					Offline queue active. The report will send as soon as connection returns.
				</div>
			</div>
		</div>
	</div>

	<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@5.21.1/dist/maplibre-gl.css" />
	<script is:inline src="https://unpkg.com/maplibre-gl@5.21.1/dist/maplibre-gl.js"></script>
	<script is:inline src="https://unpkg.com/pmtiles@3.2.1/dist/pmtiles.js"></script>
	<script is:inline src="https://unpkg.com/@protomaps/basemaps@5.0.0/dist/basemaps.js"></script>
	<script is:inline src="/reporting.js"></script>
</section>
