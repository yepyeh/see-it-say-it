---
import AppChromeShell from './AppChromeShell';
import { countUnreadNotifications } from '../lib/server/communications';

type NavItem = {
	href: string;
	label: string;
	badgeCount?: number;
};

type BreadcrumbItem = {
	href?: string;
	label: string;
	icon?: string;
};

type Props = {
	currentPath?: string;
	title?: string;
	subtitle?: string;
	actions?: NavItem[];
	breadcrumbs?: BreadcrumbItem[];
	immersiveMobile?: boolean;
};

const {
	currentPath = '/',
	title,
	subtitle,
	actions = [],
	breadcrumbs = [],
	immersiveMobile = false,
} = Astro.props;

const currentUser = Astro.locals.currentUser;
const unreadNotificationCount = currentUser
	? await countUnreadNotifications(Astro.locals, currentUser.userId)
	: 0;
const accountLabel = currentUser?.displayName ?? currentUser?.email ?? 'Guest access';

const navItems: NavItem[] = [
	{ href: '/', label: 'Home' },
	{ href: '/reports', label: 'Explore' },
	{ href: '/support', label: 'Support us' },
	{ href: '/brief', label: 'Learn more' },
	{ href: '/my-reports', label: 'Your reports' },
	{ href: '/notifications', label: 'Communications', badgeCount: unreadNotificationCount },
	{ href: '/onboarding?mode=settings', label: 'My settings' },
	{ href: '/authority', label: 'Authority' },
];
---

<AppChromeShell
	actions={actions}
	client:idle
	currentPath={currentPath}
	currentUserEmail={currentUser?.email ?? null}
	currentUserLabel={accountLabel}
	immersiveMobile={immersiveMobile}
	navItems={navItems}
	unreadNotificationCount={unreadNotificationCount}
	breadcrumbs={breadcrumbs}
	subtitle={subtitle}
	title={title}
>
	<slot />
</AppChromeShell>
