---
import Brand from './Brand.astro';
import MobileNavSheet from './MobileNavSheet';
import { buttonVariants } from './ui/button';
import { countUnreadNotifications } from '../lib/server/communications';

type NavItem = {
	href: string;
	label: string;
	badgeCount?: number;
};

type Props = {
	currentPath?: string;
	title?: string;
	subtitle?: string;
	actions?: NavItem[];
	immersiveMobile?: boolean;
};

const {
	currentPath = '/',
	title,
	subtitle,
	actions = [],
	immersiveMobile = false,
} = Astro.props;

const currentUser = Astro.locals.currentUser;
const unreadNotificationCount = currentUser
	? await countUnreadNotifications(Astro.locals, currentUser.userId)
	: 0;
const accountLabel = currentUser?.displayName ?? currentUser?.email ?? 'Guest access';

const navItems: NavItem[] = [
	{ href: '/', label: 'Home' },
	{ href: '/reports', label: 'Map' },
	{ href: '/report', label: 'Report' },
	{ href: '/my-reports', label: 'My reports' },
	{ href: '/notifications', label: 'Inbox', badgeCount: unreadNotificationCount },
	{ href: '/authority', label: 'Authority' },
];

function isActive(path: string) {
	return currentPath === path || (path !== '/' && currentPath.startsWith(path));
}
---

<div class:list={['app-shell', immersiveMobile && 'is-immersive-mobile']}>
	<aside class="app-sidebar">
		<div class="app-sidebar-top">
			<Brand />
			<div class="sidebar-copy">
				<strong>See It Say It</strong>
				<p>{currentUser ? accountLabel : 'Civic reporting, routed properly.'}</p>
			</div>
		</div>

		<nav class="app-nav">
			{navItems.map((item) => (
				<a class:list={['app-nav-link', isActive(item.href) && 'is-active']} href={item.href}>
					<span>{item.label}</span>
					{item.badgeCount ? <span class="nav-badge">{item.badgeCount}</span> : null}
				</a>
			))}
		</nav>

		<div class="app-sidebar-foot">
			{
				currentUser ? (
					<form class="shell-account-form" data-shell-logout>
						<button class:list={[buttonVariants({ variant: 'outline' }), 'shell-button']} type="submit">
							Sign out
						</button>
					</form>
				) : (
					<a class:list={[buttonVariants({ variant: 'outline' }), 'shell-button']} href="/auth?fresh=1">
						Sign in
					</a>
				)
			}
			<a class:list={[buttonVariants({ variant: 'secondary' }), 'shell-button']} href="/onboarding?mode=settings">
				Preferences
			</a>
			<a class:list={[buttonVariants({ variant: 'secondary' }), 'shell-button']} href="/inside/roadmap">Roadmap</a>
		</div>
	</aside>

	<div class="app-main">
		{
			!immersiveMobile && (
				<MobileNavSheet
					client:load
					actions={actions}
					currentPath={currentPath}
					navItems={navItems}
					currentUserEmail={currentUser?.email ?? null}
					currentUserLabel={accountLabel}
				/>
			)
		}
		{
			(title || subtitle || actions.length > 0) && (
				<header class="app-topbar">
					<div class="app-topbar-copy">
						{title && <h1>{title}</h1>}
						{subtitle && <p>{subtitle}</p>}
					</div>
					<div class="app-topbar-actions">
						{
							currentUser ? (
								<form class="topbar-account-form" data-shell-logout>
									<button class={buttonVariants({ variant: 'outline' })} type="submit">Sign out</button>
								</form>
							) : (
								<a class={buttonVariants({ variant: 'outline' })} href="/auth?fresh=1">Sign in</a>
							)
						}
						{actions.map((action) => (
							<a class={buttonVariants({ variant: 'secondary' })} href={action.href}>{action.label}</a>
						))}
					</div>
				</header>
			)
		}

		<div class="app-content">
			<slot />
		</div>
	</div>

</div>

<script is:inline>
	document.querySelectorAll('[data-shell-logout]').forEach((form) => {
		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			await fetch('/api/auth/logout', { method: 'POST' });
			window.location.href = '/auth?fresh=1';
		});
	});
</script>
