---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppChrome from '../components/AppChrome.astro';
import { HomeDashboard } from '../components/dashboard/HomeDashboard';
import { t } from '../i18n';
import '../styles/global.css';
import { getSupporterState } from '../lib/server/support';
import { listUserNotifications } from '../lib/server/communications';
import { listFollowedReports, listReports } from '../lib/server/reports';

const foundationItems = [
	{
		title: t('foundation.locale.title'),
		body: t('foundation.locale.body'),
	},
	{
		title: t('foundation.roles.title'),
		body: t('foundation.roles.body'),
	},
	{
		title: t('foundation.platform.title'),
		body: t('foundation.platform.body'),
	},
];

const workflowItems = [
	{
		title: t('workflow.capture.title'),
		body: t('workflow.capture.body'),
	},
	{
		title: t('workflow.locate.title'),
		body: t('workflow.locate.body'),
	},
	{
		title: t('workflow.categorize.title'),
		body: t('workflow.categorize.body'),
	},
	{
		title: t('workflow.detail.title'),
		body: t('workflow.detail.body'),
	},
	{
		title: t('workflow.submit.title'),
		body: t('workflow.submit.body'),
	},
];

const architectureItems = [
	{
		title: t('architecture.geography.title'),
		body: t('architecture.geography.body'),
	},
	{
		title: t('architecture.routing.title'),
		body: t('architecture.routing.body'),
	},
	{
		title: t('architecture.wardens.title'),
		body: t('architecture.wardens.body'),
	},
];

const currentUser = Astro.locals.currentUser;
const supporterState = await getSupporterState(Astro.locals, currentUser?.userId ?? null);
const userReports = currentUser ? await listReports(Astro.locals, { userId: currentUser.userId, limit: 8 }) : [];
const userNotifications = currentUser ? await listUserNotifications(Astro.locals, currentUser.userId, { limit: 4 }) : [];
const followedReports = currentUser ? await listFollowedReports(Astro.locals, currentUser.userId, { limit: 8 }) : [];
const totalConfirmations = userReports.reduce((total, report) => total + report.confirmationCount, 0);
---

<BaseLayout>
	<AppChrome
		currentPath={Astro.url.pathname}
		title={currentUser ? 'Welcome home' : 'Neighborhood reporting, routed properly.'}
		subtitle={currentUser ? 'Your reporting workspace and latest civic activity.' : 'UK-first civic reporting with live routing and an offline-safe submission path.'}
		actions={[{ href: '/report', label: 'Make a report' }]}
	>
	{currentUser ? (
		<div class="mx-auto w-full max-w-screen-2xl">
			<HomeDashboard
				followedCount={followedReports.length}
				notifications={userNotifications}
				reports={userReports}
				totalConfirmations={totalConfirmations}
			/>
		</div>
	) : (
	<div class="shell shell-in-frame">
		<section class="hero">
			<div class="hero-card page-intro-card">
				<span class="eyebrow">{t('hero.eyebrow')}</span>
				<h1>{t('hero.title')}</h1>
				<p>{t('hero.body')}</p>
				<div class="cta-row">
					<a class="button" href="/report">{t('hero.primaryCta')}</a>
					<a class="button-secondary" href="/reports">{t('hero.tertiaryCta')}</a>
					{currentUser ? <a class="button-secondary" href="/my-reports">My reports</a> : <a class="button-secondary" href="/onboarding">Start setup</a>}
				</div>
				<div class="pill-row">
					<span class="pill">{t('pill.locale')}</span>
					<span class="pill">{t('pill.roles')}</span>
					<span class="pill">{t('pill.cloudflare')}</span>
					{supporterState.badgeLabel ? <span class="pill">{supporterState.badgeLabel}</span> : null}
				</div>
				<div class="hero-summary-grid">
					<div class="signal is-soft">
						<strong>Capture</strong>
						<p>File a real issue with photos, location, severity, and public evidence.</p>
					</div>
					<div class="signal is-soft">
						<strong>Browse</strong>
						<p>Use the public map to inspect live reports, pressure points, and local activity.</p>
					</div>
					<div class="signal is-soft">
						<strong>Route</strong>
						<p>Send reports into the right authority context with clearer participation states.</p>
					</div>
				</div>
			</div>

			<aside class="panel compact-panel">
				<h2>Start here</h2>
				<p class="panel-copy">The app works best when the first visit leads quickly into one clear action.</p>
				<div class="signal-list">
					<div class="signal">
						<strong>Report an issue</strong>
						<p>Open the guided report flow and submit one real test issue end to end.</p>
					</div>
					<div class="signal">
						<strong>Open the public map</strong>
						<p>See what is already live nearby, compare severity, and inspect public timelines.</p>
					</div>
					<div class="signal">
						<strong>Set up your account</strong>
						<p>Choose your appearance and notification defaults before regular use.</p>
					</div>
				</div>
				<div class="cta-row">
					<a class="button shell-button" href="/report">Open reporting flow</a>
					<a class="button-secondary shell-button" href="/reports">Browse reports</a>
					<a class="button-secondary shell-button" href="/onboarding">Open setup</a>
				</div>
			</aside>
		</section>

		<section id="foundation">
			<div class="section-heading">
				<h2>What is live now</h2>
				<p>The core platform is no longer just a prototype. These are the strongest foundations already in place.</p>
			</div>
			<div class="foundation-grid">
				{
					foundationItems.map((item) => (
						<article class="foundation-card hero-card">
							<strong>{item.title}</strong>
							<p>{item.body}</p>
						</article>
					))
				}
			</div>
		</section>

		<section>
			<div class="section-heading">
				<h2>Public civic snapshots</h2>
				<p>Follow what is happening in a place, not just in a single report timeline.</p>
			</div>
			<div class="detail-grid">
				<article class="detail-card">
					<h2>Zones</h2>
					<p>See open pressure, fix speed, and category mix for tracked places like Bristol and Manchester.</p>
					<div class="cta-row">
						<a class="button-secondary" href="/zones">Browse zones</a>
						<a class="button-secondary" href="/zones/bristol">Open Bristol</a>
					</div>
				</article>
				<article class="detail-card">
					<h2>Authorities</h2>
					<p>Open a public authority snapshot to see recent activity, route context, and performance without entering internal tools.</p>
					<div class="cta-row">
						<a class="button-secondary" href="/authorities">Browse authorities</a>
						<a class="button-secondary" href="/authorities/bristol-city-council">Open Bristol City Council</a>
					</div>
				</article>
			</div>
		</section>

		<section>
			<div class="section-heading">
				<h2>{t('section.workflow')}</h2>
				<p>The reporting engine is structured for a state-machine style experience.</p>
			</div>
			<div class="workflow-grid">
				{
					workflowItems.map((item) => (
						<article class="workflow-card">
							<strong>{item.title}</strong>
							<p>{item.body}</p>
						</article>
					))
				}
			</div>
		</section>

		<section>
			<div class="section-heading">
				<h2>{t('section.architecture')}</h2>
				<p>These platform decisions keep the product scalable beyond the first council integrations.</p>
			</div>
			<div class="architecture-grid">
				{
					architectureItems.map((item) => (
						<article class="architecture-card hero-card">
							<strong>{item.title}</strong>
							<p>{item.body}</p>
						</article>
					))
				}
			</div>
		</section>
	</div>
	)}
	</AppChrome>
</BaseLayout>
