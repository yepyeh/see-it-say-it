---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppChrome from '../../components/AppChrome.astro';
import { Button } from '../../components/ui/button';
import '../../styles/global.css';
import { buildNotificationDigest, getNotificationTypeMeta } from '../../lib/server/communications';
import { formatPrettyDate } from '../../lib/utils';

const user = Astro.locals.currentUser;
if (!user) {
	return Astro.redirect(`/auth?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);
}

const digest = await buildNotificationDigest(Astro.locals, user.userId, { limit: 12 });
const userEmail = user.email;
---

<BaseLayout title="Digest Preview | See It Say It">
	<AppChrome
		currentPath="/notifications"
		title="Digest preview"
		subtitle="A preview of the daily-digest shape before scheduled sending is activated."
		actions={[{ href: '/notifications', label: 'Notifications' }]}
	>
		<div class="shell shell-in-frame notification-page">
			<section class="hero">
				<div class="hero-card page-intro-card">
					<span class="eyebrow">Daily digest preview</span>
					<h1>Your updates in one message.</h1>
					<p>
						This preview shows how notifications can be grouped when digest delivery is enabled later.
					</p>
					<div class="pill-row">
						<span class="pill">{digest.total} items</span>
						<span class="pill">{digest.unread} unread</span>
					</div>
					<div class="cta-row">
						<Button data-email-digest type="button" variant="secondary">Email me this digest</Button>
					</div>
				</div>
			</section>

			<section>
				<div class="section-heading is-tight">
					<h2>Grouped by event type</h2>
					<p>Newest notifications first, grouped for a calmer summary format.</p>
				</div>
				<div class="detail-grid notification-layout">
					{Object.entries(digest.grouped).map(([group, notifications]) => (
						<article class:list={['detail-card is-soft digest-group-card', `tone-${getNotificationTypeMeta(group).tone}`]}>
							<div class="inline-meta-row">
								<h2>{getNotificationTypeMeta(group).label}</h2>
								<span>{notifications.length} item{notifications.length === 1 ? '' : 's'}</span>
							</div>
							<div class="timeline-list notification-list">
								{notifications.map((notification) => (
									<div class:list={['timeline-item notification-item', `tone-${getNotificationTypeMeta(notification.notificationType).tone}`]}>
										<div class="timeline-dot"></div>
										<div>
											<strong>{notification.title}</strong>
											<p>{notification.body}</p>
											<p>{formatPrettyDate(notification.createdAt, { includeTime: true })}</p>
										</div>
									</div>
								))}
							</div>
						</article>
					))}
				</div>
			</section>
		</div>
	</AppChrome>

	<script is:inline>
		const userEmail = {JSON.stringify(userEmail)};
		const emailDigestButton = document.querySelector('[data-email-digest]');
		emailDigestButton?.addEventListener('click', async () => {
			emailDigestButton.setAttribute('disabled', 'disabled');
			emailDigestButton.textContent = 'Sending digest...';
			const response = await fetch('/api/notifications/send-digest', { method: 'POST' });
			const payload = await response.json();
			if (!response.ok) {
				emailDigestButton.removeAttribute('disabled');
				emailDigestButton.textContent = payload.error ?? 'Unable to send digest';
				return;
			}
			emailDigestButton.textContent = `Digest emailed to ${userEmail}`;
		});
	</script>
</BaseLayout>
