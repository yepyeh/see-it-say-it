---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppChrome from '../components/AppChrome.astro';
import '../styles/global.css';
import { listUserNotifications } from '../lib/server/communications';
import { listReports } from '../lib/server/reports';
import { getAuthorityScope, listAuthorityTeamMembers } from '../lib/server/auth';
import { listAccessRequests } from '../lib/server/access-requests';
import { getAuthorityParticipationByAuthorityCode } from '../lib/server/authority-participation';
import { AuthorityDashboard } from '../components/dashboard/AuthorityDashboard';

const user = Astro.locals.currentUser;
if (!user) {
	return Astro.redirect(`/auth?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);
}

const scope = getAuthorityScope(user);
const requestedAuthorityCode = Astro.url.searchParams.get('authority');
const statusFilter = Astro.url.searchParams.get('status');
const priorityFilter = Astro.url.searchParams.get('priority');
const ownerFilter = Astro.url.searchParams.get('owner');
const focusFilter = Astro.url.searchParams.get('focus');
const sortFilter = Astro.url.searchParams.get('sort') ?? 'needs-attention';
const searchFilter = Astro.url.searchParams.get('q')?.trim().toLowerCase() ?? '';
const currentOwnerLabel = user.displayName?.trim() || user.email;
const authorityCode =
	requestedAuthorityCode && (scope.isAdmin || scope.authorityCodes.includes(requestedAuthorityCode))
		? requestedAuthorityCode
		: scope.authorityCodes[0] ?? null;
const participation = authorityCode
	? await getAuthorityParticipationByAuthorityCode(Astro.locals, authorityCode)
	: null;
const allReports =
	scope.isAuthorized
		? await listReports(Astro.locals, {
				authorityCode: authorityCode ?? undefined,
				authorityCodes: authorityCode ? undefined : scope.authorityCodes,
				limit: 24,
			})
		: [];
const reports = allReports.filter((report) => {
	if (statusFilter && statusFilter !== 'all' && report.status !== statusFilter) return false;
	if (priorityFilter && priorityFilter !== 'all' && report.priority !== priorityFilter) return false;
	if (ownerFilter === 'mine') {
		if ((report.ownerLabel ?? '').trim().toLowerCase() !== currentOwnerLabel.toLowerCase()) return false;
	}
	if (ownerFilter === 'unassigned') {
		if ((report.ownerLabel ?? '').trim()) return false;
	}
	if (ownerFilter && ownerFilter !== 'all' && ownerFilter !== 'mine' && ownerFilter !== 'unassigned') {
		if ((report.ownerLabel ?? '').trim().toLowerCase() !== ownerFilter.toLowerCase()) return false;
	}
	if (!searchFilter) return true;
	return `${report.category} ${report.description} ${report.locationLabel ?? ''} ${report.reporterEmail ?? ''}`
		.toLowerCase()
		.includes(searchFilter);
}).filter((report) => {
	if (!focusFilter || focusFilter === 'all') return true;
	if (focusFilter === 'backlog') {
		return report.isHistoricBacklog;
	}
	if (focusFilter === 'overdue') {
		return Boolean(report.dueAt && new Date(report.dueAt).getTime() < Date.now() && report.status !== 'resolved');
	}
	if (focusFilter === 'stale') {
		return Date.now() - new Date(report.updatedAt).getTime() > 1000 * 60 * 60 * 48 && report.status !== 'resolved';
	}
	if (focusFilter === 'urgent') {
		return report.priority === 'urgent';
	}
	if (focusFilter === 'unassigned') {
		return !(report.ownerLabel ?? '').trim();
	}
	return true;
}).sort((first, second) => {
	const firstCreatedAt = new Date(first.createdAt).getTime();
	const secondCreatedAt = new Date(second.createdAt).getTime();
	const firstUpdatedAt = new Date(first.updatedAt).getTime();
	const secondUpdatedAt = new Date(second.updatedAt).getTime();
	const firstDueAt = first.dueAt ? new Date(first.dueAt).getTime() : Number.POSITIVE_INFINITY;
	const secondDueAt = second.dueAt ? new Date(second.dueAt).getTime() : Number.POSITIVE_INFINITY;
	const priorityWeight = { urgent: 4, high: 3, normal: 2, low: 1 } as const;
	const firstPriority = priorityWeight[first.priority as keyof typeof priorityWeight] ?? 0;
	const secondPriority = priorityWeight[second.priority as keyof typeof priorityWeight] ?? 0;
	const firstNeedsOwner = first.ownerLabel?.trim() ? 0 : 1;
	const secondNeedsOwner = second.ownerLabel?.trim() ? 0 : 1;
	const firstOverdue = first.dueAt && first.status !== 'resolved' && firstDueAt < Date.now() ? 1 : 0;
	const secondOverdue = second.dueAt && second.status !== 'resolved' && secondDueAt < Date.now() ? 1 : 0;

	switch (sortFilter) {
		case 'oldest':
			return firstCreatedAt - secondCreatedAt;
		case 'newest':
			return secondCreatedAt - firstCreatedAt;
		case 'due':
			return firstDueAt - secondDueAt;
		case 'severity':
			return second.severity - first.severity || secondCreatedAt - firstCreatedAt;
		case 'priority':
			return secondPriority - firstPriority || secondCreatedAt - firstCreatedAt;
		default:
			return (
				secondOverdue - firstOverdue ||
				secondNeedsOwner - firstNeedsOwner ||
				secondPriority - firstPriority ||
				firstDueAt - secondDueAt ||
				firstUpdatedAt - secondUpdatedAt ||
				firstCreatedAt - secondCreatedAt
			);
	}
});
const teamMembers = scope.isAuthorized
	? await listAuthorityTeamMembers(Astro.locals, {
			authorityCode: authorityCode ?? undefined,
			authorityCodes: authorityCode ? undefined : scope.authorityCodes,
		})
	: [];
const operationalNotifications = await listUserNotifications(Astro.locals, user.userId, {
	limit: 6,
	types: ['authority_action', 'routing_feedback'],
});
const queuedReports = allReports.filter((report) => report.status === 'submitted' || report.status === 'dispatched');
const activeReports = allReports.filter((report) => report.status === 'in_progress');
const resolvedReports = allReports.filter((report) => report.status === 'resolved');
const highSeverityReports = allReports.filter((report) => report.severity >= 4);
const urgentPriorityReports = allReports.filter((report) => report.priority === 'urgent');
const overdueReports = allReports.filter(
	(report) => report.dueAt && new Date(report.dueAt).getTime() < Date.now() && report.status !== 'resolved',
);
const backlogReports = allReports.filter((report) => report.isHistoricBacklog);
const adoptedBacklogReports = allReports.filter((report) => report.isAdopted);
const staleReports = allReports.filter(
	(report) => Date.now() - new Date(report.updatedAt).getTime() > 1000 * 60 * 60 * 48 && report.status !== 'resolved',
);
const myOwnedReports = allReports.filter(
	(report) => (report.ownerLabel ?? '').trim().toLowerCase() === currentOwnerLabel.toLowerCase(),
);
const unassignedReports = allReports.filter((report) => !(report.ownerLabel ?? '').trim());
const oldestOpenReport = [...allReports]
	.filter((report) => report.status !== 'resolved')
	.sort((a, b) => new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime())[0] ?? null;
const pendingAccessRequestCount = scope.isAdmin
	? (await listAccessRequests(Astro.locals, { status: 'pending', limit: 100 })).length
	: 0;
---

<BaseLayout title="Authority Dashboard | See It Say It">
	<AppChrome
		currentPath={Astro.url.pathname}
		title="Authority queue"
		subtitle="Operational view scoped to your assigned authority roles."
		actions={[{ href: '/reports', label: 'Public map' }]}
	>
		<div class="mx-auto w-full max-w-screen-2xl">
			<AuthorityDashboard
				activeReports={activeReports}
				allReports={allReports}
				authorityCode={authorityCode}
				authorityCodes={scope.authorityCodes}
				highSeverityReports={highSeverityReports}
				oldestOpenReport={oldestOpenReport}
				operationalNotifications={operationalNotifications}
				participation={participation}
				ownerFilter={ownerFilter}
				currentOwnerLabel={currentOwnerLabel}
				focusFilter={focusFilter}
				sortFilter={sortFilter}
				overdueReports={overdueReports}
				backlogReports={backlogReports}
				adoptedBacklogReports={adoptedBacklogReports}
				priorityFilter={priorityFilter}
				queuedReports={queuedReports}
				reports={reports}
				resolvedReports={resolvedReports}
				scope={scope}
				searchValue={Astro.url.searchParams.get('q') ?? ''}
				teamMembers={teamMembers}
				myOwnedReports={myOwnedReports}
				unassignedReports={unassignedReports}
				staleReports={staleReports}
				statusFilter={statusFilter}
				urgentPriorityReports={urgentPriorityReports}
				pendingAccessRequestCount={pendingAccessRequestCount}
			/>
		</div>
	</AppChrome>

	<script is:inline>
		async function readJsonSafely(response) {
			try {
				return await response.json();
			} catch (_error) {
				return { error: 'The server returned an unexpected response.' };
			}
		}

		document.querySelectorAll('[data-quick-actions]').forEach((row) => {
			row.querySelectorAll('[data-status]').forEach((button) => {
				button.addEventListener('click', async () => {
				const reportId = row.getAttribute('data-report-id');
				const status = button.getAttribute('data-status');
				const feedback = document.querySelector(`[data-status-feedback="${reportId}"]`);
				const noteField = row.closest('[data-report-surface]')?.querySelector('[data-queue-note]');
				if (!reportId || !status) return;
				button.setAttribute('disabled', 'disabled');
				if (feedback) feedback.textContent = 'Updating status...';
					try {
					const response = await fetch(`/api/authority/reports/${reportId}/status`, {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({ status, note: noteField instanceof HTMLTextAreaElement ? noteField.value : '' }),
					});
					const payload = await readJsonSafely(response);
					if (!response.ok) {
						if (feedback) feedback.textContent = payload.error ?? 'Unable to update status.';
						button.removeAttribute('disabled');
						return;
					}
					if (feedback) {
						feedback.textContent = payload.unchanged
							? `This report is already ${payload.status.replaceAll('_', ' ')}.`
							: `Status updated to ${payload.status.replaceAll('_', ' ')}. Refresh to see the latest queue ordering.`;
					}
					} catch (_error) {
						if (feedback) feedback.textContent = 'Unable to update status.';
					} finally {
						button.removeAttribute('disabled');
					}
				});
			});
		});

		document.querySelectorAll('[data-triage-form]').forEach((form) => {
			form.addEventListener('submit', async (event) => {
				event.preventDefault();
				const reportId = form.getAttribute('data-report-id');
				const feedback = form.querySelector('[data-triage-feedback]');
				if (!reportId) return;
				const formData = new FormData(form);
				if (feedback) feedback.textContent = 'Saving triage...';
				try {
					const response = await fetch(`/api/authority/reports/${reportId}/triage`, {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
							body: JSON.stringify({
								ownerLabel: String(formData.get('ownerLabel') ?? ''),
								priority: String(formData.get('priority') ?? 'normal'),
								dueAt: String(formData.get('dueAt') ?? ''),
								queueNote: String(formData.get('queueNote') ?? ''),
							}),
						});
					const payload = await readJsonSafely(response);
					if (!response.ok) {
						if (feedback) feedback.textContent = payload.error ?? 'Unable to save triage.';
						return;
					}
					if (feedback) feedback.textContent = `Triage updated to ${payload.priority}. Refresh to see queue ordering changes.`;
				} catch (_error) {
					if (feedback) feedback.textContent = 'Unable to save triage.';
				}
			});
		});

		document.querySelectorAll('[data-assign-self]').forEach((button) => {
			button.addEventListener('click', () => {
				const form = button.closest('[data-triage-form]');
				if (!form) return;
				const ownerField = form.querySelector('[name="ownerLabel"]');
				if (ownerField instanceof HTMLInputElement) {
					ownerField.value = button.getAttribute('data-owner-label') ?? '';
				}
			});
		});

		document.querySelectorAll('[data-adopt-backlog]').forEach((button) => {
			button.addEventListener('click', async () => {
				const reportId = button.getAttribute('data-adopt-backlog');
				const feedbackTarget = button.getAttribute('data-feedback-target');
				const feedback = feedbackTarget
					? document.querySelector(`[data-status-feedback="${feedbackTarget}"]`)
					: button.closest('[data-report-surface]')?.querySelector('[data-triage-feedback]');
				if (!reportId) return;
				button.setAttribute('disabled', 'disabled');
				if (feedback) feedback.textContent = 'Adopting report into monitored queue...';
				try {
					const response = await fetch(`/api/authority/reports/${reportId}/adopt`, {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({}),
					});
					const payload = await readJsonSafely(response);
					if (!response.ok) {
						if (feedback) feedback.textContent = payload.error ?? 'Unable to adopt this report right now.';
						button.removeAttribute('disabled');
						return;
					}
					if (feedback) {
						feedback.textContent =
							payload.reason === 'already_monitored'
								? 'This report is already in an authority-monitored workflow.'
								: payload.reason === 'already_adopted'
									? 'This historic report has already been adopted into the monitored queue.'
									: 'Historic backlog adopted into the monitored queue. Refresh to see updated backlog counts.';
					}
				} catch (_error) {
					if (feedback) feedback.textContent = 'Unable to adopt this report right now.';
				} finally {
					button.removeAttribute('disabled');
				}
			});
		});

		const digestButton = document.querySelector('[data-run-digests]');
		const digestFeedback = document.querySelector('[data-digest-feedback]');
		digestButton?.addEventListener('click', async () => {
			digestButton.setAttribute('disabled', 'disabled');
			if (digestFeedback) digestFeedback.textContent = 'Running digest batch...';
			const response = await fetch('/api/admin/communications/run-digests', { method: 'POST' });
			const payload = await response.json();
			if (!response.ok) {
				if (digestFeedback) digestFeedback.textContent = payload.error ?? 'Unable to run digest batch.';
				digestButton.removeAttribute('disabled');
				return;
			}
			if (digestFeedback) {
				digestFeedback.textContent = `Digest batch complete. Attempted ${payload.attempted}, sent ${payload.sent}.`;
			}
			digestButton.removeAttribute('disabled');
		});
	</script>
</BaseLayout>
