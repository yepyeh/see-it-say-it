---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppChrome from '../components/AppChrome.astro';
import { Button } from '../components/ui/button';
import {
	Card,
	CardContent,
	CardDescription,
	CardFooter,
	CardHeader,
	CardTitle,
} from '../components/ui/card';
import { Field, FieldDescription, FieldLabel } from '../components/ui/field';
import { Input } from '../components/ui/input';
import {
	InputOTP,
	InputOTPGroup,
	InputOTPSeparator,
	InputOTPSlot,
} from '../components/ui/input-otp';
import { getRuntimeEnv } from '../lib/server/db';
import '../styles/global.css';

const user = Astro.locals.currentUser;
const next = Astro.url.searchParams.get('next') ?? '/my-reports';
const turnstileSiteKey = getRuntimeEnv(Astro.locals).TURNSTILE_SITE_KEY ?? '';

if (user && Astro.url.searchParams.get('fresh') !== '1') {
	return Astro.redirect(next);
}
---

<BaseLayout title="Sign in | See It Say It" description="Request a one-time sign-in code for your reports and authority access.">
	<AppChrome
		currentPath={Astro.url.pathname}
		title="Account access"
		subtitle="Sign in with a one-time code for resident and authority access."
		actions={[{ href: '/onboarding?mode=settings', label: 'Preferences' }]}
	>
		<div class="shell shell-in-frame auth-page">
		<section class="hero auth-hero">
			<div class="hero-card page-intro-card">
				<span class="eyebrow">One-time sign-in</span>
				<h1>Use email to unlock your report history.</h1>
				<p>
					The same session works across resident, warden, authority, and admin views.
				</p>

				<Card className="auth-request-card">
					<form class="lookup-form stack" data-auth-request>
						<input name="next" type="hidden" value={next} />
						<CardHeader>
							<CardTitle>Continue with email</CardTitle>
							<CardDescription>
								Enter your details to receive a one-time sign-in code. No password is needed.
							</CardDescription>
						</CardHeader>
						<CardContent>
							<Field className="auth-field-stack">
								<Field>
									<FieldLabel htmlFor="auth-name">Full name</FieldLabel>
									<Input id="auth-name" name="name" placeholder="Jane Smith" type="text" />
								</Field>
								<Field>
									<FieldLabel htmlFor="auth-email">Email address</FieldLabel>
									<Input id="auth-email" name="email" placeholder="name@example.com" required type="email" />
									<FieldDescription>
										We only use this for sign-in codes and report updates.
									</FieldDescription>
								</Field>
								{
									turnstileSiteKey ? (
										<div class="field">
											<div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
										</div>
									) : null
								}
							</Field>
						</CardContent>
						<CardFooter className="auth-request-footer">
							<Field className="auth-otp-footer">
								<Button type="submit">Send sign-in code</Button>
								<FieldDescription>
									You can use the same session across resident and authority workflows.
								</FieldDescription>
							</Field>
						</CardFooter>
					</form>
				</Card>

				<Card className="auth-otp-card" data-auth-verify hidden>
					<form class="lookup-form stack" data-auth-verify-form>
						<input name="next" type="hidden" value={next} />
						<input name="code" type="hidden" />
						<CardHeader>
							<CardTitle>Verify your login</CardTitle>
							<CardDescription>
								Enter the verification code we sent to your email address:{' '}
								<span class="auth-email-inline" data-auth-email-inline></span>.
							</CardDescription>
						</CardHeader>
						<CardContent>
							<Field>
								<div class="auth-otp-head">
									<FieldLabel htmlFor="otp-slot-1">Verification code</FieldLabel>
									<Button data-auth-resend size="sm" type="button" variant="secondary">
										Resend code
									</Button>
								</div>
								<Input id="verify-email" name="email" readOnly type="email" />
								<InputOTP id="otp-slot-1" maxLength={6}>
									<InputOTPGroup className="auth-otp-group">
										<InputOTPSlot index={0} />
										<InputOTPSlot index={1} />
										<InputOTPSlot index={2} />
									</InputOTPGroup>
									<InputOTPSeparator className="mx-2" />
									<InputOTPGroup className="auth-otp-group">
										<InputOTPSlot index={3} />
										<InputOTPSlot index={4} />
										<InputOTPSlot index={5} />
									</InputOTPGroup>
								</InputOTP>
								<FieldDescription>
									<a href="/support">I no longer have access to this email address.</a>
								</FieldDescription>
							</Field>
							{
								turnstileSiteKey ? (
									<div class="field">
										<div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
									</div>
								) : null
							}
						</CardContent>
						<CardFooter>
							<Field className="auth-otp-footer">
								<Button type="submit">Verify and continue</Button>
								<div class="auth-otp-links">
									<Button data-auth-reset type="button" variant="ghost">Use another email</Button>
									<div class="submit-status">
										Having trouble signing in?{' '}
										<a class="auth-inline-link" href="/support">
											Contact support
										</a>
									</div>
								</div>
							</Field>
						</CardFooter>
					</form>
				</Card>

				{
					user && (
						<form class="cta-row" data-auth-logout>
							<Button type="submit" variant="secondary">Sign out</Button>
						</form>
					)
				}

				<p class="submit-status" data-auth-status></p>
			</div>

			<aside class="panel compact-panel auth-side-panel">
				<h2>What this unlocks</h2>
				<div class="signal-list">
					<div class="signal is-soft">
						<strong>My reports</strong>
						<p>No more query-string lookup. Your report history follows your account session.</p>
					</div>
					<div class="signal is-soft">
						<strong>Authority queue</strong>
						<p>Protected access now checks for assigned authority roles before loading the queue.</p>
					</div>
					<div class="signal is-soft">
						<strong>Email already wired</strong>
						<p>Codes are delivered through the configured Resend sending domain.</p>
					</div>
				</div>
			</aside>
		</section>
		</div>
	</AppChrome>

	<script is:inline>
		const requestForm = document.querySelector('[data-auth-request]');
		const verifyCard = document.querySelector('[data-auth-verify]');
		const verifyForm = document.querySelector('[data-auth-verify-form]');
		const logoutForm = document.querySelector('[data-auth-logout]');
		const resetButton = document.querySelector('[data-auth-reset]');
		const resendButton = document.querySelector('[data-auth-resend]');
		const statusBox = document.querySelector('[data-auth-status]');
		const authEmailInline = document.querySelector('[data-auth-email-inline]');
		const otpInputs = Array.from(document.querySelectorAll('[data-otp-input]'));

		const setStatus = (message) => {
			if (statusBox) statusBox.textContent = message;
		};

		const sendOtpRequest = async ({ name, email, turnstileToken }) => {
			const response = await fetch('/api/auth/request-otp', {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify({ name, email, turnstileToken }),
			});
			const result = await response.json();
			return { response, result };
		};

		requestForm?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const data = new FormData(requestForm);
			const payload = {
				name: String(data.get('name') ?? ''),
				email: String(data.get('email') ?? ''),
				turnstileToken: requestForm.querySelector('[name="cf-turnstile-response"]')?.value ?? '',
			};

			setStatus('Sending sign-in code...');
			const { response, result } = await sendOtpRequest(payload);
			if (!response.ok) {
				setStatus(result.error ?? 'Unable to send sign-in code.');
				return;
			}

			verifyCard.hidden = false;
			requestForm.hidden = true;
			verifyForm.elements.namedItem('email').value = result.email;
			if (authEmailInline) authEmailInline.textContent = result.email;
			verifyForm.elements.namedItem('code').value = '';
			otpInputs.forEach((input) => {
				input.value = '';
			});
			otpInputs[0]?.focus();
			setStatus(`A sign-in code was sent to ${result.email}.`);
		});

		const syncOtpCode = () => {
			verifyForm?.elements.namedItem('code').value = otpInputs.map((input) => input.value).join('');
		};

		otpInputs.forEach((input, index) => {
			input.addEventListener('input', () => {
				input.value = input.value.replace(/\D/g, '').slice(0, 1);
				syncOtpCode();
				if (input.value && index < otpInputs.length - 1) {
					otpInputs[index + 1].focus();
				}
			});
			input.addEventListener('keydown', (event) => {
				if (event.key === 'Backspace' && !input.value && index > 0) {
					otpInputs[index - 1].focus();
				}
			});
		});

		verifyForm?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const data = new FormData(verifyForm);
			const payload = {
				email: String(data.get('email') ?? ''),
				code: String(data.get('code') ?? ''),
				next: String(data.get('next') ?? '/my-reports'),
				turnstileToken: verifyForm.querySelector('[name="cf-turnstile-response"]')?.value ?? '',
			};

			setStatus('Verifying sign-in code...');
			const response = await fetch('/api/auth/verify-otp', {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify(payload),
			});
			const result = await response.json();
			if (!response.ok) {
				setStatus(result.error ?? 'Unable to verify sign-in code.');
				return;
			}

			window.location.href = result.next ?? '/my-reports';
		});

		resetButton?.addEventListener('click', () => {
			verifyCard.hidden = true;
			requestForm.hidden = false;
			otpInputs.forEach((input) => {
				input.value = '';
			});
			setStatus('');
		});

		resendButton?.addEventListener('click', async () => {
			const requestData = new FormData(requestForm);
			const email = String(verifyForm?.elements.namedItem('email')?.value ?? requestData.get('email') ?? '');
			const name = String(requestData.get('name') ?? '');
			if (!email) {
				setStatus('Add an email address first.');
				return;
			}
			setStatus('Sending a fresh code...');
			const { response, result } = await sendOtpRequest({
				name,
				email,
				turnstileToken: verifyForm?.querySelector('[name="cf-turnstile-response"]')?.value ?? '',
			});
			if (!response.ok) {
				setStatus(result.error ?? 'Unable to resend the sign-in code.');
				return;
			}
			otpInputs.forEach((input) => {
				input.value = '';
			});
			verifyForm.elements.namedItem('code').value = '';
			otpInputs[0]?.focus();
			setStatus(`A fresh sign-in code was sent to ${result.email}.`);
		});

		logoutForm?.addEventListener('submit', async (event) => {
			event.preventDefault();
			await fetch('/api/auth/logout', { method: 'POST' });
			window.location.href = '/auth?fresh=1';
		});
	</script>
	{turnstileSiteKey ? <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script> : null}
</BaseLayout>
