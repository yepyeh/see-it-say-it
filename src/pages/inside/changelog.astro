---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Brand from '../../components/Brand.astro';
import '../../styles/global.css';
import { changelogEntries, investorLinks, vitalSigns } from '../../data/project-status';
---

<BaseLayout
	title="Internal Changelog | See It Say It"
	description="Private-facing changelog for current shipped progress."
	robots="noindex,nofollow"
>
	<div class="shell">
		<header class="topbar">
			<Brand />
			<div class="tabbar">
				<a href={investorLinks.roadmapPath}>Roadmap</a>
				<a href="/brief">Brief</a>
			</div>
		</header>

		<section class="hero">
			<div class="hero-card">
				<span class="eyebrow">Internal changelog</span>
				<h1>Shipped milestones and what changed in the working product.</h1>
				<p>
					This changelog is written for investor and stakeholder conversations, not public
					release marketing. It reflects what is actually built and deployed.
				</p>
			</div>

			<aside class="panel">
				<h2>Snapshot</h2>
				<div class="signal-list">
					{vitalSigns.map((item) => (
						<div class="signal">
							<strong>{item.label}</strong>
							<p>{item.value}</p>
						</div>
					))}
				</div>
			</aside>
		</section>

		<section>
			<div class="section-heading">
				<h2>Release notes</h2>
				<p>Ordered newest first, aligned to what is live or committed.</p>
			</div>
			<div class="changelog-list">
				{changelogEntries.map((entry) => (
					<article class="changelog-card">
						<div class="changelog-head">
							<div>
								<h3>{entry.version}</h3>
								<p>{entry.date}</p>
							</div>
							<div class="status-pill">{entry.status}</div>
						</div>

						{entry.added.length > 0 && (
							<div class="changelog-section">
								<strong>Added</strong>
								<ul class="simple-list">
									{entry.added.map((item) => <li>{item}</li>)}
								</ul>
							</div>
						)}

						{entry.changed.length > 0 && (
							<div class="changelog-section">
								<strong>Changed</strong>
								<ul class="simple-list">
									{entry.changed.map((item) => <li>{item}</li>)}
								</ul>
							</div>
						)}

						{entry.next && entry.next.length > 0 && (
							<div class="changelog-section">
								<strong>Next</strong>
								<ul class="simple-list">
									{entry.next.map((item) => <li>{item}</li>)}
								</ul>
							</div>
						)}
					</article>
				))}
			</div>
		</section>
	</div>
</BaseLayout>
