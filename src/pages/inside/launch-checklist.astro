---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Brand from '../../components/Brand.astro';
import '../../styles/global.css';
import {
	investorLinks,
	launchChecklistSections,
	launchExecutionOrder,
	launchReadinessItems,
	vitalSigns,
} from '../../data/project-status';
---

<BaseLayout
	title="Internal Launch Checklist | See It Say It"
	description="Private-facing launch checklist for production readiness."
	robots="noindex,nofollow"
>
	<div class="shell">
		<header class="topbar">
			<Brand />
			<div class="tabbar">
				<a href={investorLinks.roadmapPath}>Roadmap</a>
				<a href={investorLinks.changelogPath}>Changelog</a>
				<a href="/brief">Brief</a>
			</div>
		</header>

		<section class="hero">
			<div class="hero-card">
				<span class="eyebrow">Internal launch checklist</span>
				<h1>Production-readiness bar for the domain migration.</h1>
				<p>
					This page separates true launch blockers from acceptable fallbacks and
					post-launch enhancements so the production move is driven by verified loops,
					not by feature creep.
				</p>
			</div>

			<aside class="panel">
				<h2>Snapshot</h2>
				<div class="signal-list">
					{vitalSigns.map((item) => (
						<div class="signal">
							<strong>{item.label}</strong>
							<p>{item.value}</p>
						</div>
					))}
				</div>
			</aside>
		</section>

		<section>
			<div class="section-heading">
				<h2>Launch readiness</h2>
				<p>Current position of the main operational loops and launch dependencies.</p>
			</div>
			<div class="roadmap-grid">
				{launchReadinessItems.map((item) => (
					<article class="roadmap-card">
						<div class="roadmap-card-head">
							<div>
								<span class:list={['status-pill', `status-${item.status}`]}>{item.status.replace('_', ' ')}</span>
								<h3>{item.title}</h3>
							</div>
							<p>{item.summary}</p>
						</div>
					</article>
				))}
			</div>
		</section>

		<section>
			<div class="section-heading">
				<h2>Execution order</h2>
				<p>Recommended sequence for the next sprint and the production cutover.</p>
			</div>
			<article class="roadmap-card">
				<ol class="simple-list">
					{launchExecutionOrder.map((item, index) => <li>{index + 1}. {item}</li>)}
				</ol>
			</article>
		</section>

		<section>
			<div class="section-heading">
				<h2>Launch criteria</h2>
				<p>Use this checklist to decide what must ship before the production domain move.</p>
			</div>
			<div class="roadmap-grid">
				{launchChecklistSections.map((section) => (
					<article class="roadmap-card">
						<div class="roadmap-card-head">
							<div>
								<span class="eyebrow eyebrow-subtle">Launch review</span>
								<h3>{section.title}</h3>
							</div>
							<p>{section.description}</p>
						</div>
						<ul class="simple-list">
							{section.items.map((item) => <li>{item}</li>)}
						</ul>
					</article>
				))}
			</div>
		</section>
	</div>
</BaseLayout>
