---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppChrome from '../components/AppChrome.astro';
import '../styles/global.css';
import {
	countUnreadNotifications,
	getNotificationPreferences,
	listUserNotifications,
	sendUserTestPush,
} from '../lib/server/communications';
import { NotificationsDashboard } from '../components/dashboard/NotificationsDashboard';

const user = Astro.locals.currentUser;
if (!user) {
	return Astro.redirect(`/auth?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);
}

const notifications = await listUserNotifications(Astro.locals, user.userId, { limit: 40 });
const unreadCount = await countUnreadNotifications(Astro.locals, user.userId);
const preferences = await getNotificationPreferences(Astro.locals, user.userId);
const userEmail = user.email;
const latestUnread = notifications.filter((notification) => !notification.readAt).slice(0, 3);
const typeFilter = Astro.url.searchParams.get('type');
const unreadOnly = Astro.url.searchParams.get('unread') === '1';
const sendTestPush = Astro.url.searchParams.get('sendTestPush') === '1';
let serverFeedback: string | null = null;

if (sendTestPush) {
	const result = await sendUserTestPush(Astro.locals, {
		userId: user.userId,
		email: user.email,
	});
	serverFeedback = !result.push.attempted
		? result.reason === 'push_disabled'
			? 'Push is not enabled for this account yet.'
			: 'No device subscription was found for this account.'
		: result.push.sent
			? `Test push sent to ${user.email}.`
			: 'Push delivery was attempted but no device accepted it.';
}

const filteredNotifications = notifications.filter((notification) => {
	if (typeFilter && notification.notificationType !== typeFilter) return false;
	if (unreadOnly && notification.readAt) return false;
	return true;
});
const typeCounts = {
	report_submitted: notifications.filter((item) => item.notificationType === 'report_submitted').length,
	status_changed: notifications.filter((item) => item.notificationType === 'status_changed').length,
	resolution_published: notifications.filter((item) => item.notificationType === 'resolution_published').length,
	support_confirmed: notifications.filter((item) => item.notificationType === 'support_confirmed').length,
	authority_action: notifications.filter((item) => item.notificationType === 'authority_action').length,
	routing_feedback: notifications.filter((item) => item.notificationType === 'routing_feedback').length,
};
---

<BaseLayout title="Notifications | See It Say It">
	<AppChrome
		currentPath={Astro.url.pathname}
		title="Notifications"
		subtitle={`Updates and delivery preferences for ${user.email}`}
		actions={[{ href: '/my-reports', label: 'My reports' }]}
	>
		<div class="mx-auto w-full max-w-screen-2xl">
			<NotificationsDashboard
				filteredNotifications={filteredNotifications}
				latestUnread={latestUnread}
				notifications={notifications}
				preferences={preferences}
				typeCounts={typeCounts}
				typeFilter={typeFilter}
				unreadCount={unreadCount}
				unreadOnly={unreadOnly}
				userEmail={userEmail}
				serverFeedback={serverFeedback}
			/>
		</div>
	</AppChrome>

	<script is:inline>
		const userEmail = {JSON.stringify(userEmail)};
		const preferencesForm = document.querySelector('[data-notification-preferences]');
		const feedback = document.querySelector('[data-notification-feedback]');
		const markAllReadButton = document.querySelector('[data-mark-all-read]');
		const markReadButtons = Array.from(document.querySelectorAll('[data-notification-read]'));
		const emailDigestButton = document.querySelector('[data-email-digest]');
		preferencesForm?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const form = event.currentTarget;
			const data = new FormData(form);
			if (feedback) feedback.textContent = 'Saving preferences...';
			const response = await fetch('/api/notifications/preferences', {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify({
					emailEnabled: data.get('emailEnabled') === 'on',
					inAppEnabled: data.get('inAppEnabled') === 'on',
					pushEnabled: data.get('pushEnabled') === 'on',
					digestMode: String(data.get('digestMode') ?? 'immediate'),
				}),
			});
			const payload = await response.json();
			if (!response.ok) {
				if (feedback) feedback.textContent = payload.error ?? 'Unable to save preferences.';
				return;
			}
			if (feedback) feedback.textContent = 'Preferences saved.';
		});

		markAllReadButton?.addEventListener('click', async () => {
			if (feedback) feedback.textContent = 'Marking notifications as read...';
			const response = await fetch('/api/notifications/read-all', { method: 'POST' });
			const payload = await response.json();
			if (!response.ok) {
				if (feedback) feedback.textContent = payload.error ?? 'Unable to mark notifications as read.';
				return;
			}
			window.location.reload();
		});

		markReadButtons.forEach((button) => {
			button.addEventListener('click', async () => {
				const notificationId = button.getAttribute('data-notification-read');
				if (!notificationId) return;
				const response = await fetch(`/api/notifications/${notificationId}/read`, { method: 'POST' });
				const payload = await response.json();
				if (!response.ok) {
					if (feedback) feedback.textContent = payload.error ?? 'Unable to mark notification as read.';
					return;
				}
				window.location.reload();
			});
		});

		emailDigestButton?.addEventListener('click', async () => {
			if (feedback) feedback.textContent = 'Sending digest email...';
			const response = await fetch('/api/notifications/send-digest', { method: 'POST' });
			const payload = await response.json();
			if (!response.ok) {
				if (feedback) feedback.textContent = payload.error ?? 'Unable to send digest email.';
				return;
			}
			if (feedback) feedback.textContent = `Digest emailed to ${userEmail}.`;
		});

	</script>
</BaseLayout>
