---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppChrome from '../../components/AppChrome.astro';
import { Button, buttonVariants } from '../../components/ui/button';
import { Badge } from '../../components/ui/badge';
import { Avatar, AvatarFallback } from '../../components/ui/avatar';
import { Progress } from '../../components/ui/progress';
import {
	Breadcrumb,
	BreadcrumbItem,
	BreadcrumbLink,
	BreadcrumbList,
	BreadcrumbPage,
	BreadcrumbSeparator,
} from '../../components/ui/breadcrumb';
import { Input } from '../../components/ui/input';
import { Textarea } from '../../components/ui/textarea';
import '../../styles/global.css';
import {
	Activity,
	CalendarDays,
	CheckCheck,
	ClipboardList,
	Clock3,
	Copy,
	MapPin,
	ShieldCheck,
	TriangleAlert,
	UserRound,
	ZoomIn,
} from 'lucide-react';
import { getReportById, listReportEvents, listResolutionStories } from '../../lib/server/reports';
import { getAuthorityScope, listAuthorityTeamMembers } from '../../lib/server/auth';
import { getAuthorityParticipationByAuthorityCode } from '../../lib/server/authority-participation';
import { getAuthorityReporterTrustSummary, getReporterAttribution } from '../../lib/server/profiles';
import { getSupporterState } from '../../lib/server/support';
import { getZoneByAuthorityCode } from '../../data/zones';
import { formatPrettyDate } from '../../lib/utils';

const reportId = Astro.params.id;
const report = reportId ? await getReportById(Astro.locals, reportId) : null;

if (!report) {
	return Astro.redirect('/reports');
}

const metaTitle = `${report.category} report | See It Say It`;
const metaDescription = `${report.description} ${report.locationLabel ? `Near ${report.locationLabel}.` : ''}`;
const ogImage = report.media[0]?.url ?? '/brand/app-icon.png';
const events = await listReportEvents(Astro.locals, report.reportId);
const resolutionStories = await listResolutionStories(Astro.locals, report.reportId);
const user = Astro.locals.currentUser;
const scope = getAuthorityScope(user);
const canOperate =
	Boolean(
		user &&
			(scope.isAdmin || user.roles.some((role) => role.authorityId && role.authorityId === report.authorityId)),
	);
const currentOwnerLabel = user?.displayName?.trim() || user?.email || '';
const teamMembers =
	canOperate && report.authorityId
		? await listAuthorityTeamMembers(Astro.locals, { authorityCodes: scope.authorityCodes })
		: [];
const reporterAttribution = await getReporterAttribution(Astro.locals, report.userId);
const reporterTrustSummary = canOperate
	? await getAuthorityReporterTrustSummary(Astro.locals, report.userId)
	: null;
const reporterSupporterState = report.userId
	? await getSupporterState(Astro.locals, report.userId)
	: null;
const participation = await getAuthorityParticipationByAuthorityCode(Astro.locals, report.authorityCode);
const zone = getZoneByAuthorityCode(report.authorityCode);
const authorityHref = report.authorityCode ? `/authorities/${report.authorityCode}` : null;

function getInitials(value: string | null | undefined) {
	if (!value) return 'SI';
	return value
		.split(/\s+/)
		.filter(Boolean)
		.slice(0, 2)
		.map((part) => part[0]?.toUpperCase() ?? '')
		.join('') || 'SI';
}

function getSeverityMeta(severity: number) {
	if (severity >= 4) {
		return { label: severity >= 5 ? 'High priority' : 'High', progress: 100, tone: 'is-high' };
	}
	if (severity === 3) {
		return { label: 'Medium', progress: 50, tone: 'is-medium' };
	}
	return { label: 'Low', progress: 25, tone: 'is-low' };
}

function prettyStatus(status: string) {
	return status.replaceAll('_', ' ');
}

function eventTone(eventType: string) {
	switch (eventType) {
		case 'resolution_story_published':
			return 'success';
		case 'report_status_updated':
			return 'accent';
		case 'authority_route_resolved':
			return 'info';
		case 'submission_email_skipped':
		case 'status_email_skipped':
			return 'muted';
		default:
			return 'support';
	}
}

function describeEvent(event: (typeof events)[number]) {
	switch (event.eventType) {
		case 'report_submitted':
			return {
				title: 'Report submitted',
				body: 'The issue entered the live queue and the first routing context was stored.',
			};
		case 'authority_route_resolved': {
			const participationState = String(event.payload.participationState ?? '');
			return {
				title: 'Authority route resolved',
				body:
					participationState === 'claimed'
						? event.payload.authorityName
							? `Matched to ${String(event.payload.authorityName)} and visible in the authority workspace.`
							: 'A council route was matched and is visible in the authority workspace.'
						: event.payload.authorityName
							? `Matched to ${String(event.payload.authorityName)}. This authority has not yet claimed its workspace in See It Say It.`
							: 'A council route was matched, but this area is not yet monitored through See It Say It.',
			};
		}
		case 'report_status_updated':
			const statusNote =
				typeof event.payload.note === 'string' && event.payload.note !== '[object Object]'
					? event.payload.note
					: null;
			return {
				title: `Status changed to ${prettyStatus(String(event.payload.toStatus ?? 'updated'))}`,
				body: statusNote || 'The report status was updated by the authority team.',
			};
		case 'report_triage_updated':
			const triageNote =
				typeof event.payload.queueNote === 'string' && event.payload.queueNote !== '[object Object]'
					? event.payload.queueNote
					: null;
			return {
				title: `Triage updated${event.payload.priority ? ` · ${String(event.payload.priority)}` : ''}`,
				body: triageNote
					? triageNote
					: event.payload.ownerLabel
						? `Assigned to ${String(event.payload.ownerLabel)}.`
						: 'Priority, ownership, or due date changed on the authority side.',
			};
		case 'resolution_story_published':
			return {
				title: 'Resolution story published',
				body: event.payload.summary ? String(event.payload.summary) : 'A public-facing resolution update was added.',
			};
		case 'authority_backlog_adopted':
			return {
				title: 'Authority adopted historic backlog',
				body:
					typeof event.payload.adoptionNote === 'string' && event.payload.adoptionNote.trim()
						? String(event.payload.adoptionNote)
						: 'This report has now been adopted into the monitored authority queue.',
			};
		case 'submission_email_sent':
			return {
				title: 'Submission email sent',
				body: 'The resident confirmation email was delivered through the transactional email pipeline.',
			};
		case 'status_email_sent':
			return {
				title: 'Status email sent',
				body: 'A resident status update email was sent.',
			};
		case 'submission_email_skipped':
		case 'status_email_skipped':
			return {
				title: prettyStatus(event.eventType),
				body: 'Email delivery was skipped because digest mode or preferences deferred the message.',
			};
		default:
			return {
				title: prettyStatus(event.eventType),
				body: event.actorName ?? event.actorEmail ?? 'Recorded in the activity timeline.',
			};
	}
}

const severityMeta = getSeverityMeta(report.severity);
const reporterLabel = reporterAttribution?.label ?? report.reporterName ?? 'Community member';
---

<BaseLayout title={metaTitle} description={metaDescription} ogImage={ogImage}>
	<AppChrome
		currentPath="/reports"
		title={report.category}
		subtitle="Track the public report, evidence, and accountability history."
		actions={[{ href: '/report', label: 'New report' }]}
	>
		<div class="mx-auto w-full max-w-5xl" data-report-detail-root data-report-id={report.reportId}>
			<div class="report-detail-breadcrumb">
				<Breadcrumb>
					<BreadcrumbList>
						<BreadcrumbItem>
							<BreadcrumbLink href="/">Home</BreadcrumbLink>
						</BreadcrumbItem>
						{zone ? (
							<>
								<BreadcrumbSeparator />
								<BreadcrumbItem>
									<BreadcrumbLink href={`/zones/${zone.slug}`}>{zone.name}</BreadcrumbLink>
								</BreadcrumbItem>
							</>
						) : null}
						<BreadcrumbSeparator />
						<BreadcrumbItem>
							<BreadcrumbLink href="/reports">Reports</BreadcrumbLink>
						</BreadcrumbItem>
						<BreadcrumbSeparator />
						<BreadcrumbItem>
							<BreadcrumbPage>#{report.reportId.slice(0, 8)}</BreadcrumbPage>
						</BreadcrumbItem>
					</BreadcrumbList>
				</Breadcrumb>
			</div>
			<section class="detail-hero">
				<div class="hero-card page-intro-card">
					<span class="eyebrow">Report detail</span>
					<h1>{report.category}</h1>
					<p>{report.description}</p>
					<div class="pill-row">
						<Badge variant="outline">Severity {report.severity}</Badge>
						<Badge variant="secondary">{report.status.replace('_', ' ')}</Badge>
						<Badge variant="outline">{participation.label}</Badge>
						{
							authorityHref ? (
								<a class="pill" href={authorityHref}>{report.authorityName ?? 'Routing pending'}</a>
							) : (
								<span class="pill">{report.authorityName ?? 'Routing pending'}</span>
							)
						}
						{zone ? <a class="pill" href={`/zones/${zone.slug}`}>{zone.name}</a> : null}
					</div>
					<div class="report-detail-meta-grid">
						<div class="report-detail-meta-line">
							<MapPin class="report-detail-meta-icon" />
							<span>{report.locationLabel ?? 'Location not yet labelled'}</span>
						</div>
						<div class="report-detail-meta-line">
							<Clock3 class="report-detail-meta-icon" />
							<span>{formatPrettyDate(report.createdAt, { includeTime: true })}</span>
						</div>
					</div>
					<div class:list={['report-severity-card', severityMeta.tone]}>
						<div class="report-severity-copy">
							<div class="report-severity-heading">
								<TriangleAlert class="report-detail-meta-icon" />
								<strong>Severity</strong>
							</div>
							<p>Level {report.severity} · {severityMeta.label}</p>
						</div>
						<Progress class="report-severity-progress" value={severityMeta.progress} />
					</div>
				</div>
			</section>

			<section class="detail-grid">
				<article class="detail-card is-soft">
					<h2>Current status</h2>
					<div class="report-detail-meta-line">
						<Activity class="report-detail-meta-icon" />
						<p>{prettyStatus(report.status)}</p>
					</div>
				</article>
				<article class="detail-card is-soft">
					<h2>Created</h2>
					<div class="report-detail-meta-line">
						<CalendarDays class="report-detail-meta-icon" />
						<p>{formatPrettyDate(report.createdAt, { includeTime: true })}</p>
					</div>
				</article>
				<article class="detail-card is-soft">
					<h2>Authority</h2>
					<div class="report-detail-meta-line">
						<ShieldCheck class="report-detail-meta-icon" />
						{
							authorityHref ? (
								<p><a href={authorityHref}>{report.authorityName ?? 'Routing pending'}</a></p>
							) : (
								<p>{report.authorityName ?? 'Routing pending'}</p>
							)
						}
					</div>
					{zone ? <p><a href={`/zones/${zone.slug}`}>Zone: {zone.name}</a></p> : null}
					<p>{participation.shortDescription}</p>
				</article>
				<article class="detail-card is-soft">
					<h2>Monitoring</h2>
					<div class="report-detail-meta-line">
						<ClipboardList class="report-detail-meta-icon" />
						<p>{participation.label}</p>
					</div>
					<p>{participation.description}</p>
					{
						!participation.isMonitored && authorityHref ? (
							<div class="cta-row">
								<a class={buttonVariants({ size: 'sm', variant: 'secondary' })} href={authorityHref}>Open authority page</a>
								<a class={buttonVariants({ size: 'sm', variant: 'outline' })} href={`${authorityHref}/open-letter`}>Open letter</a>
								<a class={buttonVariants({ size: 'sm', variant: 'outline' })} href="/apply/access">Apply for authority access</a>
							</div>
						) : null
					}
				</article>
				<article class="detail-card is-soft">
					<h2>Reporter</h2>
					<div class="reporter-summary">
						<Avatar>
							<AvatarFallback>{getInitials(reporterLabel)}</AvatarFallback>
						</Avatar>
						<div class="reporter-summary-copy">
							{
								reporterAttribution?.profileHref ? (
									<p><a href={reporterAttribution.profileHref}>{reporterLabel}</a></p>
								) : (
									<p>{reporterLabel}</p>
								)
							}
							<p>{report.reporterEmail ? 'Submitted from a signed-in account.' : 'Submitted without a linked account.'}</p>
						</div>
					</div>
					{reporterSupporterState?.badgeLabel ? <p>{reporterSupporterState.badgeLabel}</p> : null}
				</article>
				<article class="detail-card is-soft">
					<h2>Triage</h2>
					<div class="report-operational-block">
						<div class="report-detail-meta-line">
							<ClipboardList class="report-detail-meta-icon" />
							<p>Priority: {report.priority}</p>
						</div>
						<div class="report-detail-meta-line">
							<UserRound class="report-detail-meta-icon" />
							<p>Owner: {report.ownerLabel ?? 'Unassigned'}</p>
						</div>
						<div class="report-detail-meta-line">
							<CalendarDays class="report-detail-meta-icon" />
							<p>Due: {report.dueAt ? formatPrettyDate(report.dueAt) : 'No due date set'}</p>
						</div>
					</div>
					{report.isHistoricBacklog ? <p>Historic public backlog awaiting authority adoption.</p> : null}
					{report.isAdopted ? <p>Historic backlog adopted {report.adoptedAt ? `on ${formatPrettyDate(report.adoptedAt, { includeTime: true })}` : ''}.</p> : null}
				</article>
				<article class="detail-card is-soft">
					<h2>Community confirmations</h2>
					<div class="report-signal-badges">
						<Badge variant="secondary"><CheckCheck class="report-badge-icon" /> {report.confirmationCount} confirmations</Badge>
						<Badge variant="outline"><Copy class="report-badge-icon" /> {report.duplicateCount} possible duplicates</Badge>
					</div>
					<p>{report.confirmationCount} residents have confirmed that they can see this issue too.</p>
				</article>
				{
					canOperate && reporterTrustSummary ? (
						<article class="detail-card is-soft">
							<h2>Reporter trust summary</h2>
							<p>Account age: {reporterTrustSummary.accountAgeDays} days</p>
							<p>Reports submitted: {reporterTrustSummary.reportCount}</p>
							<p>Resolved reports: {reporterTrustSummary.resolvedCount}</p>
							<p>Confirmations made: {reporterTrustSummary.confirmationsMade}</p>
							<p>Last 30 days: {reporterTrustSummary.last30DayReports}</p>
							<p>Authorities used: {reporterTrustSummary.distinctAuthorityCount}</p>
							{
								reporterTrustSummary.riskFlags.length ? (
									<ul class="signal-list">
										{reporterTrustSummary.riskFlags.map((flag) => (
											<li class="signal">
												<strong>Signal</strong>
												<p>{flag}</p>
											</li>
										))}
									</ul>
								) : (
									<p>No elevated trust signals detected.</p>
								)
							}
						</article>
					) : null
				}
			</section>

			<section class="detail-grid">
				<article class="detail-card is-soft">
					<h2>Location</h2>
					<div class="report-detail-meta-line">
						<MapPin class="report-detail-meta-icon" />
						<p>{report.locationLabel ?? 'No reverse-geocoded location captured yet.'}</p>
					</div>
					<p>{report.latitude.toFixed(5)}, {report.longitude.toFixed(5)}</p>
				</article>
				<article class="detail-card is-soft">
					<h2>Evidence</h2>
					{
						report.media.length ? (
							<div class="media-grid">
								{report.media.map((media) => (
									<a class="report-media-frame" href={media.url} target="_blank" rel="noreferrer">
										<img src={media.url} alt={`Evidence for ${report.category}`} loading="lazy" />
										<span class="report-media-overlay"><ZoomIn class="report-media-overlay-icon" /></span>
									</a>
								))}
							</div>
						) : (
							<p>No image evidence was attached to this report.</p>
						)
					}
				</article>
				<article class="detail-card is-soft">
					<h2>Notes</h2>
					<p>{report.notesMarkdown || 'No additional notes were supplied.'}</p>
				</article>
				<article class="detail-card is-soft">
					<h2>Community signal</h2>
					<div class="report-signal-badges">
						<Badge variant="secondary"><CheckCheck class="report-badge-icon" /> {report.confirmationCount} confirmations</Badge>
						<Badge variant="outline"><Copy class="report-badge-icon" /> {report.duplicateCount} nearby duplicates</Badge>
					</div>
					<div class="report-signal-strength">
						<div class="report-detail-meta-line">
							<Activity class="report-detail-meta-icon" />
							<strong>Community signal strength</strong>
						</div>
						<Progress value={Math.min(((report.confirmationCount + report.duplicateCount) / 6) * 100, 100)} />
					</div>
					<Button data-confirm-report={report.reportId} type="button">Confirm this issue</Button>
					<p class="inline-feedback" data-confirm-feedback></p>
				</article>
			</section>

			<section class="detail-grid">
				<article class="detail-card is-soft">
					<h2>Timeline</h2>
					<div class="timeline-list resident-timeline-list">
						{events.map((event) => {
							const summary = describeEvent(event);
							return (
							<div class:list={['timeline-item resident-timeline-item', `tone-${eventTone(event.eventType)}`]}>
								<div class="timeline-dot"></div>
								<div>
									<strong>{summary.title}</strong>
									<p>{formatPrettyDate(event.createdAt, { includeTime: true })}</p>
									<p>{summary.body}</p>
									{event.actorName || event.actorEmail ? (
										<p>Recorded by {event.actorName ?? event.actorEmail}</p>
									) : null}
								</div>
							</div>
						)})}
					</div>
				</article>

				<article class="detail-card is-soft">
					<h2>Resolution stories</h2>
					{
						resolutionStories.length ? (
							<div class="timeline-list resident-timeline-list">
								{resolutionStories.map((story) => (
									<div class="timeline-item resident-timeline-item tone-success">
										<div class="timeline-dot"></div>
										<div>
											<strong>{story.summary}</strong>
											<p>{formatPrettyDate(story.createdAt, { includeTime: true })}</p>
									{story.notes ? <p>{story.notes}</p> : null}
											{story.media.length ? (
												<div class="media-grid">
													{story.media.map((media) => (
														<a class="report-media-frame" href={media.url} rel="noreferrer" target="_blank">
															<img alt={`Resolution media for ${report.category}`} loading="lazy" src={media.url} />
															<span class="report-media-overlay"><ZoomIn class="report-media-overlay-icon" /></span>
														</a>
													))}
												</div>
											) : null}
										</div>
									</div>
								))}
							</div>
						) : (
							<p>No resolution story has been published for this report yet.</p>
						)
					}
				</article>

				{
					canOperate && (
						<article class="detail-card is-soft">
							<h2>Authority action</h2>
							<p>Update the status and leave an operational note for the timeline and resident email.</p>
							<label class="field">
								<span>Owner</span>
								<Input
									data-triage-owner
									list="report-owner-options"
									type="text"
									value={report.ownerLabel ?? ''}
									placeholder="Crew, contractor, named owner"
								/>
								<datalist id="report-owner-options">
									{teamMembers.map((member) => {
										const ownerValue = (member.displayName?.trim() || member.email).trim();
										return <option value={ownerValue} />;
									})}
								</datalist>
							</label>
							<div class="authority-status-row">
								<label class="field">
									<span>Priority</span>
									<select data-triage-priority class="h-9 rounded-lg border border-input bg-background px-3 text-sm">
										<option selected={report.priority === 'low'} value="low">Low</option>
										<option selected={report.priority === 'normal'} value="normal">Normal</option>
										<option selected={report.priority === 'high'} value="high">High</option>
										<option selected={report.priority === 'urgent'} value="urgent">Urgent</option>
									</select>
								</label>
								<label class="field">
									<span>Due date</span>
									<input
										data-triage-due
										class="h-9 rounded-lg border border-input bg-background px-3 text-sm"
										type="date"
										value={report.dueAt ? report.dueAt.slice(0, 10) : ''}
									/>
								</label>
							</div>
							<div class="authority-status-row">
								<Button data-assign-self={currentOwnerLabel} size="sm" type="button" variant="outline">
									Assign to me
								</Button>
								<Button data-triage-save size="sm" type="button" variant="secondary">
									Save triage
								</Button>
							</div>
							<label class="field">
								<span>Queue note</span>
								<Textarea
									data-queue-note
									defaultValue={report.queueNote === '[object Object]' ? '' : report.queueNote ?? ''}
									rows={3}
									placeholder="Owner confirmed, contractor booked, or next operational step."
								/>
							</label>
							<p class="inline-feedback" data-triage-feedback></p>
							{
								report.isHistoricBacklog ? (
									<>
										<hr />
										<h3>Historic backlog</h3>
										<p>This report was originally submitted before this authority started monitoring through See It Say It. Adopt it to move it into the active monitored queue.</p>
										<Button data-adopt-backlog={report.reportId} type="button" variant="outline">Adopt into monitored queue</Button>
										<p class="inline-feedback" data-adoption-feedback></p>
									</>
								) : null
							}
							<hr />
							<div class="authority-status-row">
								<Button data-authority-status="dispatched" size="sm" type="button" variant="secondary">
									Mark dispatched
								</Button>
								<Button data-authority-status="in_progress" size="sm" type="button" variant="secondary">
									Mark in progress
								</Button>
								<Button data-authority-status="resolved" size="sm" type="button">
									Mark resolved
								</Button>
							</div>
							<label class="field">
								<span>Operational note</span>
								<Textarea data-authority-note rows={4} placeholder="Crew booked, duplicate confirmed, issue resolved, or other useful context." />
							</label>
							<p class="inline-feedback" data-authority-feedback></p>
							<hr />
							<h3>Publish resolution story</h3>
							<p>Add a public-facing summary with optional after-photo evidence.</p>
							<label class="field">
								<span>Resolution summary</span>
								<Textarea data-resolution-summary rows={3} placeholder="Pavement repaired, obstruction cleared, and safe access restored." />
							</label>
							<label class="field">
								<span>Internal or extra notes</span>
								<Textarea data-resolution-notes rows={4} placeholder="Useful extra context for the public timeline." />
							</label>
							<label class="field">
								<span>After photo</span>
								<input data-resolution-file accept="image/*" type="file" />
							</label>
							<Button data-resolution-submit type="button">Publish resolution story</Button>
							<p class="inline-feedback" data-resolution-feedback></p>
						</article>
					)
				}
			</section>

			<div class="card-actions">
				<a class={buttonVariants({ variant: 'secondary' })} href="/reports">Back to reports</a>
				{canOperate ? <a class={buttonVariants({ variant: 'secondary' })} href="/authority">Open authority queue</a> : null}
			</div>
		</div>
	</AppChrome>

	<script is:inline>
		async function readJsonSafely(response) {
			try {
				return await response.json();
			} catch (_error) {
				return { error: 'The server returned an unexpected response.' };
			}
		}

		const reportDetailRoot = document.querySelector('[data-report-detail-root]');
		const currentReportId = reportDetailRoot?.getAttribute('data-report-id') ?? '';
		const button = document.querySelector('[data-confirm-report]');
		const feedback = document.querySelector('[data-confirm-feedback]');
		button?.addEventListener('click', async () => {
			const reportId = button.getAttribute('data-confirm-report');
			if (!reportId) return;
			button.setAttribute('disabled', 'disabled');
			const response = await fetch(`/api/reports/${reportId}/confirm`, {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify({}),
			});
			const payload = await response.json();
			feedback.textContent = `Confirmed. Total confirmations: ${payload.confirmationCount}.`;
			button.textContent = 'Confirmed';
		});

		const authorityButtons = Array.from(document.querySelectorAll('[data-authority-status]')).filter(
			(node) => node instanceof HTMLButtonElement,
		);
		const authorityFeedback = document.querySelector('[data-authority-feedback]');
		const authorityNote = document.querySelector('[data-authority-note]');
		const triageQueueNote = document.querySelector('[data-queue-note]');
		const authorityNoteValue =
			authorityNote instanceof HTMLTextAreaElement ? () => authorityNote.value : () => '';
		const triageQueueNoteValue =
			triageQueueNote instanceof HTMLTextAreaElement ? () => triageQueueNote.value : () => '';
		const triageOwner = document.querySelector('[data-triage-owner]');
		const triagePriority = document.querySelector('[data-triage-priority]');
		const triageDue = document.querySelector('[data-triage-due]');
		const triageFeedback = document.querySelector('[data-triage-feedback]');
		const triageSaveButton = document.querySelector('[data-triage-save]');
		const assignSelfButton = document.querySelector('[data-assign-self]');
		const adoptionButton = document.querySelector('[data-adopt-backlog]');
		const adoptionFeedback = document.querySelector('[data-adoption-feedback]');
		if (assignSelfButton instanceof HTMLButtonElement && triageOwner instanceof HTMLInputElement) {
			assignSelfButton.addEventListener('click', () => {
				triageOwner.value = assignSelfButton.getAttribute('data-assign-self') ?? '';
			});
		}
		if (triageSaveButton instanceof HTMLButtonElement) {
			triageSaveButton.addEventListener('click', async () => {
				triageSaveButton.setAttribute('disabled', 'disabled');
				if (triageFeedback) triageFeedback.textContent = 'Saving triage...';
				try {
					const response = await fetch(`/api/authority/reports/${currentReportId}/triage`, {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({
							ownerLabel: triageOwner instanceof HTMLInputElement ? triageOwner.value : '',
							priority: triagePriority instanceof HTMLSelectElement ? triagePriority.value : 'normal',
							dueAt: triageDue instanceof HTMLInputElement ? triageDue.value : '',
							queueNote: triageQueueNoteValue(),
						}),
					});
					const payload = await readJsonSafely(response);
					if (!response.ok) {
						if (triageFeedback) triageFeedback.textContent = payload.error ?? 'Unable to save triage.';
						triageSaveButton.removeAttribute('disabled');
						return;
					}
					if (triageFeedback) triageFeedback.textContent = `Triage updated to ${payload.priority}. Refresh to see the latest snapshot.`;
				} catch (error) {
					console.error('report detail triage client error', error);
					if (triageFeedback) triageFeedback.textContent = error instanceof Error ? error.message : 'Unable to save triage.';
				} finally {
					triageSaveButton.removeAttribute('disabled');
				}
			});
		}
		if (adoptionButton instanceof HTMLButtonElement) {
			adoptionButton.addEventListener('click', async () => {
				adoptionButton.setAttribute('disabled', 'disabled');
				if (adoptionFeedback) adoptionFeedback.textContent = 'Adopting report into monitored queue...';
				try {
					const response = await fetch(`/api/authority/reports/${currentReportId}/adopt`, {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({ note: authorityNoteValue() }),
					});
					const payload = await readJsonSafely(response);
					if (!response.ok) {
						if (adoptionFeedback) adoptionFeedback.textContent = payload.error ?? 'Unable to adopt the report right now.';
						adoptionButton.removeAttribute('disabled');
						return;
					}
					if (adoptionFeedback) {
						adoptionFeedback.textContent =
							payload.reason === 'already_monitored'
								? 'This report is already in an authority-monitored workflow.'
								: payload.reason === 'already_adopted'
									? 'This historic report has already been adopted into the monitored queue.'
									: 'Historic backlog adopted into the monitored queue. Refresh to see the updated status.';
					}
				} catch (error) {
					console.error('backlog adoption client error', error);
					if (adoptionFeedback) adoptionFeedback.textContent = error instanceof Error ? error.message : 'Unable to adopt the report right now.';
				} finally {
					adoptionButton.removeAttribute('disabled');
				}
			});
		}
		authorityButtons.forEach((actionButton) => {
			actionButton.addEventListener('click', async () => {
				actionButton.setAttribute('disabled', 'disabled');
				if (authorityFeedback) authorityFeedback.textContent = 'Updating status...';
				try {
					const response = await fetch(`/api/authority/reports/${currentReportId}/status`, {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({
							status: actionButton.getAttribute('data-authority-status'),
							note: authorityNoteValue(),
						}),
					});
					const payload = await readJsonSafely(response);
					if (!response.ok) {
						if (authorityFeedback) authorityFeedback.textContent = payload.error ?? 'Unable to update the report.';
						actionButton.removeAttribute('disabled');
						return;
					}
					if (authorityFeedback) {
						authorityFeedback.textContent = payload.unchanged
							? `This report is already ${payload.status.replaceAll('_', ' ')}.`
							: `Status updated to ${payload.status.replaceAll('_', ' ')}. Refresh to see the latest timeline.`;
					}
				} catch (error) {
					console.error('authority status client error', error);
					if (authorityFeedback) authorityFeedback.textContent = error instanceof Error ? error.message : 'Unable to update the report right now.';
					actionButton.removeAttribute('disabled');
				}
			});
		});

		const resolutionButton = document.querySelector('[data-resolution-submit]');
		const resolutionFeedback = document.querySelector('[data-resolution-feedback]');
		const resolutionSummary = document.querySelector('[data-resolution-summary]');
		const resolutionNotes = document.querySelector('[data-resolution-notes]');
		const resolutionFile = document.querySelector('[data-resolution-file]');
		const resolutionSummaryValue =
			resolutionSummary instanceof HTMLTextAreaElement ? () => resolutionSummary.value.trim() : () => '';
		const resolutionNotesValue =
			resolutionNotes instanceof HTMLTextAreaElement ? () => resolutionNotes.value : () => '';
		const resolutionFileInput = resolutionFile instanceof HTMLInputElement ? resolutionFile : null;
		if (resolutionButton instanceof HTMLButtonElement) {
		resolutionButton.addEventListener('click', async () => {
			const summary = resolutionSummaryValue();
			if (!summary) {
				if (resolutionFeedback) resolutionFeedback.textContent = 'Add a summary before publishing the resolution story.';
				return;
			}
			resolutionButton.setAttribute('disabled', 'disabled');
			if (resolutionFeedback) resolutionFeedback.textContent = 'Publishing resolution story...';
			try {
				const media = [];
				const file = resolutionFileInput?.files?.[0];
				if (file) {
					const uploadBody = new FormData();
					uploadBody.set('file', file);
					const uploadResponse = await fetch('/api/uploads/report-media', {
						method: 'POST',
						body: uploadBody,
					});
					const uploadPayload = await uploadResponse.json().catch(() => ({
						error: 'Unable to upload the resolution image.',
					}));
					if (!uploadResponse.ok) {
						if (resolutionFeedback) resolutionFeedback.textContent = uploadPayload.error ?? 'Unable to upload the resolution image.';
						resolutionButton.removeAttribute('disabled');
						return;
					}
					media.push(uploadPayload.media);
				}
				const response = await fetch(`/api/authority/reports/${currentReportId}/resolution-story`, {
					method: 'POST',
					headers: { 'content-type': 'application/json' },
					body: JSON.stringify({
						summary,
						notes: resolutionNotesValue(),
						media,
					}),
				});
				const payload = await response.json().catch(() => ({
					error: 'Unable to publish the resolution story right now.',
				}));
				if (!response.ok) {
					if (resolutionFeedback) resolutionFeedback.textContent = payload.error ?? 'Unable to publish the resolution story.';
					resolutionButton.removeAttribute('disabled');
					return;
				}
				if (resolutionFeedback) resolutionFeedback.textContent = 'Resolution story published. Refresh to see it in the public timeline.';
				if (resolutionSummary instanceof HTMLTextAreaElement) resolutionSummary.value = '';
				if (resolutionNotes instanceof HTMLTextAreaElement) resolutionNotes.value = '';
				if (resolutionFileInput) resolutionFileInput.value = '';
			} catch (error) {
				console.error('resolution story client error', error);
				if (resolutionFeedback) resolutionFeedback.textContent = error instanceof Error ? error.message : 'Unable to publish the resolution story right now.';
				resolutionButton.removeAttribute('disabled');
			}
		});
		}
	</script>
</BaseLayout>
