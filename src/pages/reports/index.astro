---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { listReports } from '../../lib/server/reports';

const reports = await listReports(Astro.locals, { limit: 24 });
---

<BaseLayout title="Public Reports | See It Say It" description="Browse recent community issue reports and confirm nearby cases.">
	<div class="shell">
		<header class="topbar">
			<div class="brand">
				<span class="brand-mark">SI</span>
				<span>See It Say It</span>
			</div>
			<nav class="tabbar">
				<a href="/">Overview</a>
				<a href="/report">Report</a>
				<a href="/my-reports">My Reports</a>
			</nav>
		</header>

		<section class="hero">
			<div class="hero-card">
				<span class="eyebrow">Public map feed</span>
				<h1>Recent reports in the live queue.</h1>
				<p>
					This public feed is the first working replacement for the future mapped view.
					It helps reduce duplicate reporting and gives the community visible status.
				</p>
			</div>
			<aside class="panel">
				<h2>Feed notes</h2>
				<div class="signal-list">
					<div class="signal">
						<strong>Duplicate signal</strong>
						<p>Reports track nearby duplicates and community confirmations.</p>
					</div>
					<div class="signal">
						<strong>Authority routing</strong>
						<p>The current prototype auto-matches seeded UK authorities from rough geographic boxes.</p>
					</div>
				</div>
			</aside>
		</section>

		<section>
			<div class="section-heading">
				<h2>Recent submissions</h2>
				<p>{reports.length} reports currently available.</p>
			</div>
			<div class="report-list">
				{
					reports.map((report) => (
						<article class="report-card">
							<div class="report-card-top">
								<div>
									<div class="status-pill">{report.status.replace('_', ' ')}</div>
									<h3>{report.category}</h3>
								</div>
								<div class="severity-badge">Severity {report.severity}</div>
							</div>
							<p>{report.description}</p>
							<dl class="report-meta">
								<div>
									<dt>Location</dt>
									<dd>{report.locationLabel ?? `${report.latitude.toFixed(4)}, ${report.longitude.toFixed(4)}`}</dd>
								</div>
								<div>
									<dt>Authority</dt>
									<dd>{report.authorityName ?? 'Routing pending'}</dd>
								</div>
								<div>
									<dt>Confirmations</dt>
									<dd>{report.confirmationCount}</dd>
								</div>
								<div>
									<dt>Duplicates</dt>
									<dd>{report.duplicateCount}</dd>
								</div>
							</dl>
							<div class="card-actions">
								<a class="button-secondary" href={`/reports/${report.reportId}`}>Open report</a>
							</div>
						</article>
					))
				}
			</div>
		</section>
	</div>
</BaseLayout>
