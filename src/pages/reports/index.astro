---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppChrome from '../../components/AppChrome.astro';
import PublicReportsMap from '../../components/reporting/PublicReportsMap';
import '../../styles/global.css';
import { listReports } from '../../lib/server/reports';

const reports = await listReports(Astro.locals, { limit: 24 });
---

<BaseLayout title="Public Reports | See It Say It" description="Browse recent community issue reports and confirm nearby cases.">
	<AppChrome
		currentPath={Astro.url.pathname}
		title="Public reports"
		subtitle="Browse nearby submissions and reduce duplicate reporting."
		actions={[{ href: '/report', label: 'Report issue' }]}
	>
		<div class="shell shell-in-frame">
		<section class="hero">
			<div class="hero-card">
				<span class="eyebrow">Public map</span>
				<h1>Recent reports on the live map.</h1>
				<p>
					Browse recent reports spatially, inspect duplicates, and open the public timeline
					for any issue on the map.
				</p>
			</div>
			<aside class="panel">
				<h2>Feed notes</h2>
				<div class="signal-list">
					<div class="signal">
						<strong>Duplicate signal</strong>
						<p>Reports track nearby duplicates and community confirmations.</p>
					</div>
					<div class="signal">
						<strong>Authority routing</strong>
						<p>The current build resolves UK authorities from live ONS LAD boundary data.</p>
					</div>
				</div>
			</aside>
		</section>

		<section>
			<div class="section-heading">
				<h2>Mapped submissions</h2>
				<p>{reports.length} reports currently available.</p>
			</div>
			<PublicReportsMap client:load reports={reports} />
		</section>
		</div>
	</AppChrome>
	<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@5.21.1/dist/maplibre-gl.css" />
</BaseLayout>
