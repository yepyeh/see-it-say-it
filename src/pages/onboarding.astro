---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppChrome from '../components/AppChrome.astro';
import OnboardingDashboard from '../components/dashboard/OnboardingDashboard';
import SettingsDashboard from '../components/dashboard/SettingsDashboard';
import '../styles/global.css';
import { getNotificationPreferences } from '../lib/server/communications';
import { getRuntimeEnv } from '../lib/server/db';

const currentUser = Astro.locals.currentUser;
const mode = Astro.url.searchParams.get('mode');
const notificationPreferences = currentUser
	? await getNotificationPreferences(Astro.locals, currentUser.userId)
	: null;
const vapidPublicKey = getRuntimeEnv(Astro.locals).VAPID_PUBLIC_KEY ?? '';
---

<BaseLayout title="Onboarding | See It Say It" description="Set permissions and preferences for your reporting experience.">
	{
		mode === 'settings' ? (
			<AppChrome
				currentPath="/onboarding"
				title="Preferences"
				subtitle="Device, permission, and communication settings."
				actions={[{ href: '/notifications', label: 'Inbox' }]}
			>
				<SettingsDashboard
					client:load
					initialPreferences={notificationPreferences}
					isSignedIn={Boolean(currentUser)}
					userEmail={currentUser?.email ?? null}
					vapidPublicKey={vapidPublicKey}
				/>
			</AppChrome>
		) : (
			<AppChrome
				currentPath="/onboarding"
				title="Onboarding"
				subtitle="Set permissions and preferences before the first report."
				actions={[{ href: '/report', label: 'Report now' }]}
			>
				<OnboardingDashboard
					client:load
					initialPreferences={notificationPreferences}
					isSignedIn={Boolean(currentUser)}
					vapidPublicKey={vapidPublicKey}
				/>
			</AppChrome>
		)
	}
</BaseLayout>
