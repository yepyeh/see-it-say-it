---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import { listReports } from '../lib/server/reports';

const email = Astro.url.searchParams.get('email');
const reports = email ? await listReports(Astro.locals, { email, limit: 24 }) : [];
const queued = Astro.url.searchParams.get('queued') === '1';
---

<BaseLayout title="My Reports | See It Say It">
	<div class="shell">
		<header class="topbar">
			<div class="brand">
				<span class="brand-mark">SI</span>
				<span>See It Say It</span>
			</div>
			<nav class="tabbar">
				<a href="/">Overview</a>
				<a href="/report">Report</a>
				<a href="/reports">Public feed</a>
			</nav>
		</header>

		<section class="hero">
			<div class="hero-card">
				<span class="eyebrow">My reports</span>
				<h1>Track your submitted and queued issues.</h1>
				<p>
					This prototype uses email lookup instead of full OTP authentication so the report
					pipeline can be exercised immediately.
				</p>
				{
					queued && (
						<p class="notice-banner">
							Your report was queued offline and will submit when connectivity returns.
						</p>
					)
				}
				<form class="lookup-form" method="get">
					<label>
						<span>Email address</span>
						<input name="email" type="email" value={email ?? ''} placeholder="name@example.com" />
					</label>
					<button class="button" type="submit">Find my reports</button>
				</form>
			</div>
		</section>

		{
			email && (
				<section>
					<div class="section-heading">
						<h2>Results</h2>
						<p>{reports.length} reports linked to {email}.</p>
					</div>
					<div class="report-list">
						{reports.map((report) => (
							<article class="report-card">
								<div class="report-card-top">
									<div>
										<div class="status-pill">{report.status.replace('_', ' ')}</div>
										<h3>{report.category}</h3>
									</div>
									<div class="severity-badge">Severity {report.severity}</div>
								</div>
								<p>{report.description}</p>
								<div class="card-actions">
									<a class="button-secondary" href={`/reports/${report.reportId}`}>Open report</a>
								</div>
							</article>
						))}
					</div>
				</section>
			)
		}
	</div>
</BaseLayout>
