---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppChrome from '../components/AppChrome.astro';
import '../styles/global.css';
import { Badge } from '../components/ui/badge';
import { buttonVariants } from '../components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '../components/ui/card';
import { Separator } from '../components/ui/separator';
import { getNotificationTypeMeta, listUserNotifications } from '../lib/server/communications';
import { listReports } from '../lib/server/reports';
import { getSupporterState } from '../lib/server/support';
import { getRuntimeEnv } from '../lib/server/db';
import { formatPrettyDate } from '../lib/utils';

const user = Astro.locals.currentUser;
if (!user) {
	return Astro.redirect(`/auth?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);
}

const reports = await listReports(Astro.locals, { userId: user.userId, limit: 24 });
const queued = Astro.url.searchParams.get('queued') === '1';
const supporterState = await getSupporterState(Astro.locals, user.userId);
const recentNotifications = await listUserNotifications(Astro.locals, user.userId, { limit: 3 });
const openReports = reports.filter((report) => report.status !== 'resolved');
const resolvedReports = reports.filter((report) => report.status === 'resolved');
const totalConfirmations = reports.reduce((total, report) => total + report.confirmationCount, 0);
const highestSeverity = reports.reduce((highest, report) => Math.max(highest, report.severity), 0);
const vapidPublicKey = getRuntimeEnv(Astro.locals).VAPID_PUBLIC_KEY ?? '';
---

<BaseLayout title="My Reports | See It Say It">
	<AppChrome
		currentPath={Astro.url.pathname}
		title="My reports"
		subtitle={`Signed in as ${user.email}`}
		actions={[{ href: '/notifications', label: 'Inbox' }, { href: '/auth', label: 'Manage sign-in' }]}
	>
		<div class="shell shell-in-frame">
		<section class="hero">
			<div class="hero-card page-intro-card">
				<span class="eyebrow">My reports</span>
				<h1>{reports.length ? 'Track your submitted and queued issues.' : 'Start your reporting history.'}</h1>
				<p>
					Signed in as {user.email}. Your reports and confirmations are now scoped from the
					active session rather than an email query string.
				</p>
				{
					supporterState.isSupporter && (
						<div class="pill-row">
							<Badge variant="secondary">Supporter</Badge>
							<Badge variant="outline">Backing the platform since {formatPrettyDate(supporterState.latestContributionAt, { includeTime: true })}</Badge>
						</div>
					)
				}
				{
					queued && (
						<p class="notice-banner">
							Your report was queued offline and will submit when connectivity returns.
						</p>
					)
				}
			</div>
		</section>

			<section>
				<div class="detail-grid">
					<Card className="detail-card is-soft">
						<CardHeader>
							<CardTitle>Open issues</CardTitle>
							<CardDescription>{openReports.length} still awaiting a final outcome.</CardDescription>
						</CardHeader>
					</Card>
					<Card className="detail-card is-soft">
						<CardHeader>
							<CardTitle>Resolved</CardTitle>
							<CardDescription>{resolvedReports.length} closed reports on this account.</CardDescription>
						</CardHeader>
					</Card>
					<Card className="detail-card is-soft">
						<CardHeader>
							<CardTitle>Community confirmations</CardTitle>
							<CardDescription>{totalConfirmations} confirmations across your tracked issues.</CardDescription>
						</CardHeader>
					</Card>
					<Card className="detail-card is-soft">
						<CardHeader>
							<CardTitle>Highest severity</CardTitle>
							<CardDescription>{highestSeverity ? `Severity ${highestSeverity}` : 'No reports yet'}</CardDescription>
						</CardHeader>
					</Card>
				</div>
			</section>

		<section>
			<div class="section-heading is-tight">
				<h2>Results</h2>
				<p>{reports.length} reports linked to your signed-in account.</p>
			</div>
			{
				reports.length ? (
					<div class="report-list">
						{reports.map((report) => (
							<Card className="report-card is-soft">
								<div class="report-card-top">
									<div>
										<div class="status-pill">{report.status.replace('_', ' ')}</div>
										<h3>{report.category}</h3>
									</div>
									<div class="severity-badge">Severity {report.severity}</div>
								</div>
								<Separator className="my-3" />
								<p>{report.description}</p>
								<dl class="report-meta">
									<div>
										<dt>Location</dt>
										<dd>{report.locationLabel ?? `${report.latitude.toFixed(4)}, ${report.longitude.toFixed(4)}`}</dd>
									</div>
									<div>
										<dt>Created</dt>
										<dd>{formatPrettyDate(report.createdAt, { includeTime: true })}</dd>
									</div>
									<div>
										<dt>Community</dt>
										<dd>{report.confirmationCount} confirmations</dd>
									</div>
									<div>
										<dt>Authority</dt>
										<dd>{report.authorityName ?? 'Routing pending'}</dd>
									</div>
								</dl>
								<div class="card-actions">
									<a class="button-secondary" href={`/reports/${report.reportId}`}>Open report</a>
								</div>
							</Card>
						))}
					</div>
				) : (
					<div class="detail-grid">
						<article class="detail-card">
							<h2>Report your first issue</h2>
							<p>This account has no linked reports yet. The fastest way to populate this timeline is to open the live map-led reporting flow.</p>
							<div class="cta-row">
								<a class="button" href="/report">Open report flow</a>
								<a class="button-secondary" href="/reports">Browse public reports</a>
							</div>
						</article>
						<article class="detail-card">
							<h2>Keep the loop closed</h2>
							<p>Enable notifications on this device and keep your preferences current so authority updates are harder to miss.</p>
							<div class="cta-row">
								<button class="button-secondary" data-enable-notifications type="button">Enable notifications</button>
								<a class="button-secondary" href="/onboarding?mode=settings">Open preferences</a>
								{!supporterState.isSupporter ? <a class="button-secondary" href="/support">Support the platform</a> : null}
							</div>
							<p class="submit-status" data-notification-status></p>
						</article>
					</div>
				)
			}
		</section>

		<section>
			<div class="section-heading is-tight">
				<h2>Recent updates</h2>
				<p>The newest communication events tied to your account.</p>
			</div>
			{
				recentNotifications.length ? (
					<div class="detail-grid resident-update-grid">
						{recentNotifications.map((notification) => (
							<Card class:list={['detail-card is-soft resident-update-card', `tone-${getNotificationTypeMeta(notification.notificationType).tone}`]}>
								<div class="inline-meta-row">
									<strong>{notification.title}</strong>
									<span>{formatPrettyDate(notification.createdAt, { includeTime: true })}</span>
								</div>
								<Separator className="my-3" />
								<p>{notification.body}</p>
								<div class="pill-row">
									<Badge class:list={['notification-pill', `tone-${getNotificationTypeMeta(notification.notificationType).tone}`]} variant="outline">{getNotificationTypeMeta(notification.notificationType).label}</Badge>
									{!notification.readAt ? <Badge variant="secondary">Unread</Badge> : null}
								</div>
								<div class="card-actions">
									{notification.ctaPath ? (
										<a class={buttonVariants({ variant: 'secondary' })} href={notification.ctaPath}>Open</a>
									) : null}
									<a class={buttonVariants({ variant: 'secondary' })} href="/notifications">Open inbox</a>
								</div>
							</Card>
						))}
					</div>
				) : (
					<div class="detail-card is-soft">
						<h2>No recent updates yet</h2>
						<p>Once reports move, support activates, or authority actions happen, they will appear here and in the inbox.</p>
						<div class="cta-row">
							<a class="button-secondary" href="/notifications">Open inbox</a>
						</div>
					</div>
				)
			}
		</section>
		</div>
	</AppChrome>

	<script is:inline>
		const vapidPublicKey = {JSON.stringify(vapidPublicKey)};
		const notificationButton = document.querySelector('[data-enable-notifications]');
		const notificationStatus = document.querySelector('[data-notification-status]');
		const toUint8Array = (base64) => {
			const padding = '='.repeat((4 - (base64.length % 4)) % 4);
			const normalized = (base64 + padding).replace(/-/g, '+').replace(/_/g, '/');
			const binary = atob(normalized);
			return Uint8Array.from(binary, (char) => char.charCodeAt(0));
		};

		const subscribeToPush = async () => {
			if (!vapidPublicKey) {
				if (notificationStatus) notificationStatus.textContent = 'Browser notifications are enabled. Push delivery will activate once the VAPID public key is configured.';
				return;
			}
			if (!('serviceWorker' in navigator)) {
				if (notificationStatus) notificationStatus.textContent = 'Service workers are not supported on this device.';
				return;
			}
			const registration = await navigator.serviceWorker.ready;
			const existing = await registration.pushManager.getSubscription();
			const subscription =
				existing ??
				(await registration.pushManager.subscribe({
					userVisibleOnly: true,
					applicationServerKey: toUint8Array(vapidPublicKey),
				}));
			const response = await fetch('/api/notifications/subscribe', {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify(subscription),
			});
			const payload = await response.json();
			if (!response.ok) {
				if (notificationStatus) notificationStatus.textContent = payload.error ?? 'Unable to register push notifications.';
				return;
			}
			if (notificationStatus) notificationStatus.textContent = 'Push subscription saved for this device.';
		};

		notificationButton?.addEventListener('click', async () => {
			if (!('Notification' in window)) {
				if (notificationStatus) notificationStatus.textContent = 'Notifications are not supported on this device.';
				return;
			}
			const result = await Notification.requestPermission();
			if (result === 'granted') {
				await subscribeToPush();
				return;
			}
			if (notificationStatus) notificationStatus.textContent = 'Notifications permission was not granted.';
		});
	</script>
</BaseLayout>
