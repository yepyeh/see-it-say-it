---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReportFlowShell from '../components/ReportFlowShell.astro';
import '../styles/global.css';
---

<BaseLayout title="Report an Issue | See It Say It">
	<div class="shell">
		<header class="topbar">
			<div class="brand">
				<span class="brand-mark">SI</span>
				<span>See It Say It</span>
			</div>
			<nav class="tabbar">
				<a href="/">Overview</a>
				<a href="/reports">Public feed</a>
				<a href="/my-reports">My Reports</a>
			</nav>
		</header>

		<ReportFlowShell />
	</div>
</BaseLayout>
