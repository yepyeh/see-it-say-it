---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppChrome from '../components/AppChrome.astro';
import ReportExperience from '../components/reporting/ReportExperience';
import '../styles/global.css';
---

<BaseLayout title="Report an Issue | See It Say It">
	<AppChrome
		currentPath={Astro.url.pathname}
		immersiveMobile={true}
		title="Report an issue"
		subtitle="Mobile now uses a real Vaul drawer with the map behind it. Desktop keeps the same readable workflow in a wider frame."
		actions={[{ href: '/reports', label: 'View map' }]}
	>
		<div class="report-page-shell">
			<ReportExperience
				client:load
				initialEmail={Astro.locals.currentUser?.email ?? ''}
				initialName={Astro.locals.currentUser?.displayName ?? ''}
			/>
		</div>
	</AppChrome>
	<script is:inline src="https://unpkg.com/pmtiles@3.2.1/dist/pmtiles.js"></script>
	<script is:inline src="https://unpkg.com/@protomaps/basemaps@5.0.0/dist/basemaps.js"></script>
</BaseLayout>
